{%- comment -%} ══ DYNAMISCHE ADD-ONS ══ {%- endcomment -%}
{%- assign rendered_choice_groups = '' -%}
{%- for block in section.blocks -%}

  {%- comment -%} ── Textfeld ── {%- endcomment -%}
  {%- if block.type == 'opt_text' -%}
    <div class="gw-form-field" {{ block.shopify_attributes }}>
      <label class="gw-form-label" for="addon-{{ block.id }}">
        {{ block.settings.label }}
        {%- if block.settings.surcharge_cents > 0 -%}<span class="gw-option-price gw-option-price--inline">(+{{ block.settings.surcharge_cents | money_without_currency }}€)</span>{%- endif -%}
        {%- if block.settings.required -%}<span class="gw-required-mark"> *</span>{%- endif -%}
      </label>
      <div class="gw-form-input-wrap">
        <input type="text" id="addon-{{ block.id }}" class="gw-form-input"
          placeholder="{{ block.settings.placeholder | escape }}"
          {%- if block.settings.max_chars > 0 %}maxlength="{{ block.settings.max_chars }}"{%- endif %}
          data-addon="text" data-block="{{ block.id }}"
          data-fkey="{{ block.settings.field_key | escape }}"
          data-surcharge="{{ block.settings.surcharge_cents | default: 0 }}"
          data-variant="{{ block.settings.addon_variant_id | default: 0 }}"
          data-required="{{ block.settings.required }}"
          autocomplete="off">
        {%- if block.settings.show_char_counter and block.settings.max_chars > 0 -%}
          <span class="gw-char-count" data-counter="{{ block.id }}">0/{{ block.settings.max_chars }}</span>
        {%- endif -%}
      </div>
    </div>

  {%- comment -%} ── Checkbox ── {%- endcomment -%}
  {%- elsif block.type == 'opt_checkbox' -%}
    <label class="gw-giftwrap-row" {{ block.shopify_attributes }}>
      <span>
        {%- if block.settings.icon != blank -%}{{ block.settings.icon }} {%- endif -%}
        {{ block.settings.label }}
        {%- if block.settings.description != blank -%}
          <span class="gw-addon-description">{{ block.settings.description }}</span>
        {%- endif -%}
      </span>
      <span class="gw-giftwrap-right">
        {%- if block.settings.surcharge_cents > 0 -%}<span class="gw-giftwrap-price">+{{ block.settings.surcharge_cents | money }}</span>{%- endif -%}
        <input type="checkbox" id="addon-{{ block.id }}"
          data-addon="checkbox" data-block="{{ block.id }}"
          data-fkey="{{ block.settings.field_key | escape }}"
          data-surcharge="{{ block.settings.surcharge_cents | default: 0 }}"
          data-variant="{{ block.settings.addon_variant_id | default: 0 }}"
          {% if block.settings.default_checked %}checked{% endif %}>
      </span>
    </label>

  {%- comment -%} ── Auswahl-Gruppe ── {%- endcomment -%}
  {%- elsif block.type == 'opt_choice' -%}
    {%- assign gid = block.settings.group_id -%}
    {%- unless rendered_choice_groups contains gid -%}
      {%- assign rendered_choice_groups = rendered_choice_groups | append: gid | append: '§' -%}
      {%- assign dt = block.settings.display_type | default: 'buttons' -%}
      {%- assign glabel = block.settings.group_label | default: gid -%}
      {%- assign fkey = block.settings.field_key | default: glabel -%}
      <div class="gw-form-field" data-addon="choice-group" data-gid="{{ gid }}" data-fkey="{{ fkey | escape }}" {{ block.shopify_attributes }}>
        <p class="gw-form-label">{{ glabel }}</p>
        {%- if dt == 'dropdown' -%}
          <select class="gw-form-input" data-addon="choice-select" data-gid="{{ gid }}">
            {%- for inner in section.blocks -%}
              {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                <option value="{{ inner.settings.choice_value | escape }}"
                  data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                  data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                  {% if inner.settings.is_default %}selected{% endif %}>
                  {{ inner.settings.choice_label }}{% if inner.settings.surcharge_cents > 0 %} (+{{ inner.settings.surcharge_cents | money_without_currency }}€){% endif %}
                </option>
              {%- endif -%}
            {%- endfor -%}
          </select>
        {%- elsif dt == 'swatches' -%}
          <div class="gw-thread-grid">
            {%- for inner in section.blocks -%}
              {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                <button type="button"
                  class="gw-thread-swatch{% if inner.settings.is_default %} is-active{% endif %}"
                  data-addon="choice-btn" data-gid="{{ gid }}"
                  data-val="{{ inner.settings.choice_value | escape }}"
                  data-lbl="{{ inner.settings.choice_label | escape }}"
                  data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                  data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                  title="{{ inner.settings.choice_label | escape }}" aria-label="{{ inner.settings.choice_label | escape }}"
                  {{ inner.shopify_attributes }}>
                  <span class="gw-thread-swatch__dot" style="background:{{ inner.settings.hex_color | default: '#ccc' | escape }};"></span>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- elsif dt == 'images' -%}
          <div class="gw-beads-grid">
            {%- for inner in section.blocks -%}
              {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                <button type="button"
                  class="gw-bead-btn{% if inner.settings.is_default %} is-active{% endif %}"
                  data-addon="choice-btn" data-gid="{{ gid }}"
                  data-val="{{ inner.settings.choice_value | escape }}"
                  data-lbl="{{ inner.settings.choice_label | escape }}"
                  data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                  data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                  {{ inner.shopify_attributes }}>
                  <div class="gw-bead-btn__img">
                    {%- if inner.settings.choice_image != blank -%}
                      <img src="{{ inner.settings.choice_image | image_url: width: 200 }}" alt="{{ inner.settings.choice_label | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: inner.settings.choice_image.aspect_ratio | round }}">
                    {%- elsif inner.settings.hex_color != blank -%}
                      <div class="gw-bead-btn__color" style="background:{{ inner.settings.hex_color | escape }};"></div>
                    {%- else -%}
                      <div class="gw-bead-btn__none">{{ inner.settings.choice_label | slice: 0 }}</div>
                    {%- endif -%}
                  </div>
                  <div class="gw-bead-btn__info">
                    <span class="gw-bead-btn__name">{{ inner.settings.choice_label }}</span>
                    <span class="gw-bead-btn__price">{% if inner.settings.surcharge_cents > 0 %}+{{ inner.settings.surcharge_cents | money_without_currency }}€{% else %}—{% endif %}</span>
                  </div>
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="gw-sympos-grid gw-sympos-grid--wrap">
            {%- for inner in section.blocks -%}
              {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                <button type="button"
                  class="gw-sympos-btn{% if inner.settings.is_default %} is-active{% endif %}"
                  data-addon="choice-btn" data-gid="{{ gid }}"
                  data-val="{{ inner.settings.choice_value | escape }}"
                  data-lbl="{{ inner.settings.choice_label | escape }}"
                  data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                  data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                  {{ inner.shopify_attributes }}>
                  {{ inner.settings.choice_label }}
                  {%- if inner.settings.surcharge_cents > 0 -%}<span class="gw-choice-price"> +{{ inner.settings.surcharge_cents | money_without_currency }}€</span>{%- endif -%}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endunless -%}

  {%- comment -%} ── Produkt-Auswahl ── {%- endcomment -%}
  {%- elsif block.type == 'opt_product' -%}
    {%- assign linked_product = all_products[block.settings.product] -%}
    {%- if linked_product != blank -%}
      {%- assign opt_dt = block.settings.display_type | default: 'image_grid' -%}
      <div class="gw-form-field" {{ block.shopify_attributes }}>
        <p class="gw-product__section-label">{{ block.settings.label }} <span>Optional</span></p>
        {%- if opt_dt == 'dropdown' -%}
          <select class="gw-form-input"
            data-addon="product-select" data-block="{{ block.id }}"
            data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
            data-separate="{{ block.settings.separate_line_item }}">
            {%- if block.settings.include_none -%}
              <option value="" data-price="0" data-variant="0">{{ block.settings.none_label | default: 'Keine' }}</option>
            {%- endif -%}
            {%- for v in linked_product.variants -%}
              <option value="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}">
                {{ v.title }} (+{{ v.price | money_without_currency }}€)
              </option>
            {%- endfor -%}
          </select>
        {%- elsif opt_dt == 'list' -%}
          <div class="gw-product-radio-list">
            {%- if block.settings.include_none -%}
              <label class="gw-product-radio">
                <input type="radio" name="opt-p-{{ block.id }}" value="" data-price="0" data-variant="0"
                  data-addon="product-radio" data-block="{{ block.id }}"
                  data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                  data-separate="{{ block.settings.separate_line_item }}" checked>
                {{ block.settings.none_label | default: 'Keine' }}
              </label>
            {%- endif -%}
            {%- for v in linked_product.variants -%}
              <label class="gw-product-radio">
                <input type="radio" name="opt-p-{{ block.id }}" value="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}"
                  data-addon="product-radio" data-block="{{ block.id }}"
                  data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                  data-separate="{{ block.settings.separate_line_item }}">
                {{ v.title }} (+{{ v.price | money_without_currency }}€)
              </label>
            {%- endfor -%}
          </div>
        {%- else -%}
          <div class="gw-beads-grid">
            {%- if block.settings.include_none -%}
              <button type="button" class="gw-bead-btn is-active"
                data-addon="product-card" data-block="{{ block.id }}"
                data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                data-separate="{{ block.settings.separate_line_item }}"
                data-val="" data-price="0" data-variant="0">
                <div class="gw-bead-btn__img"><div class="gw-bead-btn__none">{{ block.settings.none_label | default: 'Keine' | slice: 0 }}</div></div>
                <div class="gw-bead-btn__info">
                  <span class="gw-bead-btn__name">{{ block.settings.none_label | default: 'Keine' }}</span>
                  <span class="gw-bead-btn__price">—</span>
                </div>
              </button>
            {%- endif -%}
            {%- for v in linked_product.variants -%}
              <button type="button" class="gw-bead-btn"
                data-addon="product-card" data-block="{{ block.id }}"
                data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                data-separate="{{ block.settings.separate_line_item }}"
                data-val="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}">
                <div class="gw-bead-btn__img">
                  {%- if v.featured_image -%}
                    <img src="{{ v.featured_image | image_url: width: 200 }}" alt="{{ v.title | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: v.featured_image.aspect_ratio | round }}">
                  {%- elsif linked_product.featured_image -%}
                    <img src="{{ linked_product.featured_image | image_url: width: 200 }}" alt="{{ v.title | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: linked_product.featured_image.aspect_ratio | round }}">
                  {%- else -%}
                    <div class="gw-bead-btn__none">?</div>
                  {%- endif -%}
                </div>
                <div class="gw-bead-btn__info">
                  <span class="gw-bead-btn__name">{{ v.title }}</span>
                  <span class="gw-bead-btn__price">+{{ v.price | money_without_currency }}€</span>
                </div>
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  {%- endif -%}
{%- endfor -%}
