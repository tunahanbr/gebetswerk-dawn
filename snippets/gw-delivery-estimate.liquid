{%- comment -%}
  Dynamische Lieferzeit-Anzeige (Standard / Express).

  Rechenmodell (siehe assets/gebetswerk-delivery.js):
    1. Bearbeitung: zählt nur an den gewählten Bearbeitungstagen (auch Wochenende
       möglich). Bestellungen nach Redaktionsschluss starten einen Tag später.
    2. Versandübergabe: das fertige Paket geht am selben Tag raus, wenn er ein
       Versandtag ist, sonst am nächsten Versandtag (typisch Mo–Fr).
    3. Versanddauer: zählt Mo–Fr, bei aktivierter Samstagszustellung auch Sa.

  Parameter (alle optional):
    s             - section.settings des Aufrufers; liefert alle delivery_*-Werte
                    aus dem Theme-Editor (Tage, Uhrzeit, Texte)
    express       - true/false  initialer Zustand (Standard: false)
    auto_express  - true        beobachtet die Express-Checkbox der Produktseite
                                 und schaltet automatisch um
    compact       - true        kompaktere Darstellung (z. B. Cart-Drawer)
    label / standard_note / express_note / express_hint
                  - Text-Overrides; gewinnen gegenüber s

  Verwendung:
    {%- render 'gw-delivery-estimate', auto_express: true, s: section.settings -%}
    {%- render 'gw-delivery-estimate', express: has_express, compact: true -%}
{%- endcomment -%}

{{ 'gebetswerk-delivery.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign gw_label = label | default: s.delivery_label | default: 'Voraussichtliche Lieferung'
  assign gw_std_note = standard_note | default: s.delivery_standard_text | default: 'Standard-Anfertigung: 2–4 Werktage + Versand (AT 1–2, DE 2–4 Tage).'
  assign gw_exp_note = express_note | default: s.delivery_express_text | default: 'Wir starten sofort mit deiner Bestellung – bevorzugt vor allen anderen.'
  assign gw_hint = express_hint | default: s.delivery_express_hint | default: 'Das genaue Zustelldatum hängt zusätzlich vom Versanddienstleister ab.'
  assign gw_cutoff = s.delivery_cutoff | default: '14:00'

  comment
    Tages-Masken als 7-stellige Bitstrings, Index = JS getDay() (0 = Sonntag).
  endcomment
  assign gw_day_keys = 'so,mo,di,mi,do,fr,sa' | split: ','
  if s
    assign gw_work_days = ''
    assign gw_ship_days = ''
    for k in gw_day_keys
      assign gw_wid = 'delivery_work_' | append: k
      assign gw_sid = 'delivery_ship_' | append: k
      if s[gw_wid]
        assign gw_work_days = gw_work_days | append: '1'
      else
        assign gw_work_days = gw_work_days | append: '0'
      endif
      if s[gw_sid]
        assign gw_ship_days = gw_ship_days | append: '1'
      else
        assign gw_ship_days = gw_ship_days | append: '0'
      endif
    endfor
  else
    assign gw_work_days = '1111111'
    assign gw_ship_days = '0111110'
  endif

  assign gw_sat_delivery = true
  if s and s.delivery_sat_delivery == false
    assign gw_sat_delivery = false
  endif
-%}

<div
  class="gw-delivery{% if compact %} gw-delivery--compact{% endif %}"
  data-express="{% if express %}true{% else %}false{% endif %}"
  data-auto-express="{% if auto_express %}true{% else %}false{% endif %}"
  data-work-days="{{ gw_work_days }}"
  data-ship-days="{{ gw_ship_days }}"
  data-sat-delivery="{{ gw_sat_delivery }}"
  data-cutoff="{{ gw_cutoff }}"
  data-prod-min="{{ s.delivery_prod_min | default: 2 }}"
  data-prod-max="{{ s.delivery_prod_max | default: 4 }}"
  data-ship-min="{{ s.delivery_ship_min | default: 1 }}"
  data-ship-max="{{ s.delivery_ship_max | default: 4 }}"
  data-exp-prod-min="{{ s.delivery_exp_prod_min | default: 1 }}"
  data-exp-prod-max="{{ s.delivery_exp_prod_max | default: 1 }}"
  data-exp-ship-min="{{ s.delivery_exp_ship_min | default: 1 }}"
  data-exp-ship-max="{{ s.delivery_exp_ship_max | default: 2 }}"
  aria-live="polite"
>
  {%- comment -%} Standard {%- endcomment -%}
  <div class="gw-delivery__state" data-state="standard"{% if express %} hidden{% endif %}>
    <span class="gw-delivery__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    </span>
    <div class="gw-delivery__body">
      <p class="gw-delivery__label">{{ gw_label }}</p>
      <p class="gw-delivery__date" data-date>…</p>
      <p class="gw-delivery__note">{{ gw_std_note }}</p>
    </div>
  </div>

  {%- comment -%} Express {%- endcomment -%}
  <div class="gw-delivery__state gw-delivery__state--express" data-state="express"{% unless express %} hidden{% endunless %}>
    <span class="gw-delivery__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M13 2 4.5 13.5H11l-1 8.5L19.5 10H13z"/></svg>
    </span>
    <div class="gw-delivery__body">
      <p class="gw-delivery__label">{{ gw_label }} <span class="gw-delivery__tag">Express</span></p>
      <p class="gw-delivery__date" data-date>…</p>
      <p class="gw-delivery__note">{{ gw_exp_note }}</p>
      {%- if gw_hint != blank -%}<p class="gw-delivery__hint">{{ gw_hint }}</p>{%- endif -%}
    </div>
  </div>
</div>

<script src="{{ 'gebetswerk-delivery.js' | asset_url }}" defer></script>
