{% comment %}
  Judge.me Widgets Snippet
  Wird von Judge.me automatisch befüllt wenn "Install theme code" geklickt wurde.
  Die direkten jdgm-* Divs in den Templates funktionieren auch ohne diesen Snippet
  sobald das Judge.me App Embed aktiviert ist.
{% endcomment %}

{%- assign jdgm_product = product -%}

{%- if widget_type == 'judgeme_widgets' -%}
  <div class="jdgm-widget jdgm-review-widget"
    data-id="{{ jdgm_product.id }}"
    data-product-title="{{ jdgm_product.title | escape }}"
    data-product-url="{{ shop.url }}{{ jdgm_product.url }}">
  </div>
{%- endif -%}

{%- if widget_type == 'preview_badge' or widget_type == 'star_rating' -%}
  <div class="jdgm-widget jdgm-prev-badge"
    data-id="{{ jdgm_product.id }}"
    data-product-title="{{ jdgm_product.title | escape }}"
    data-product-url="{{ shop.url }}{{ jdgm_product.url }}">
  </div>
{%- endif -%}
