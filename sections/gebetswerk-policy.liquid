{{ 'gebetswerk-policy-section.css' | asset_url | stylesheet_tag }}
<div class="gw-policy-page">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  <nav class="gw-policy-breadcrumb" aria-label="Breadcrumb">
    <div class="gw-policy-breadcrumb__inner">
      <a href="{{ routes.root_url }}">
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" width="14" height="14"><path d="M3 10l7-7 7 7"/><path d="M5 8v9h4v-5h2v5h4V8"/></svg>
        Home
      </a>
      <span class="gw-policy-breadcrumb__sep">/</span>
      <span>{{ page.title }}</span>
    </div>
  </nav>

  <div class="gw-policy-layout">

    {%- comment -%} Sidebar Navigation {%- endcomment -%}
    <aside class="gw-policy-sidebar">
      <p class="gw-policy-sidebar__heading">Rechtliches</p>
      <nav>
        <ul class="gw-policy-sidebar__list">
          <li class="{% if request.path contains 'legal-notice' %}gw-policy-sidebar__item--active{% endif %}">
            <a href="/policies/legal-notice">Impressum</a>
          </li>
          <li class="{% if request.path contains 'privacy-policy' %}gw-policy-sidebar__item--active{% endif %}">
            <a href="/policies/privacy-policy">Datenschutzerklärung</a>
          </li>
          <li class="{% if request.path contains 'terms-of-service' %}gw-policy-sidebar__item--active{% endif %}">
            <a href="/policies/terms-of-service">AGB</a>
          </li>
          <li class="{% if request.path contains 'refund-policy' %}gw-policy-sidebar__item--active{% endif %}">
            <a href="/policies/refund-policy">Widerrufsrecht & Rückgabe</a>
          </li>
          <li class="{% if request.path contains 'shipping-policy' %}gw-policy-sidebar__item--active{% endif %}">
            <a href="/policies/shipping-policy">Versand & Lieferung</a>
          </li>
        </ul>

        <div class="gw-policy-sidebar__contact">
          <p class="gw-policy-sidebar__contact-label">Fragen?</p>
          <a href="/pages/contact" class="gw-policy-sidebar__contact-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Kontakt aufnehmen
          </a>
        </div>
      </nav>
    </aside>

    {%- comment -%} Policy Content {%- endcomment -%}
    <article class="gw-policy-content">
      <header class="gw-policy-content__header">
        <p class="gw-policy-content__eyebrow">Rechtliches</p>
        <h1 class="gw-policy-content__title">{{ page.title }}</h1>
      </header>
      <div class="gw-policy-content__body gw-rte">
        {{ page.content }}
      </div>
    </article>

  </div>
</div>


{% schema %}
{
  "name": "Policy-Seite",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "Policy-Seite"
    }
  ]
}
{% endschema %}
