{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign inv = current_variant.inventory_quantity | default: 0
  assign inv_threshold = section.settings.inventory_threshold | default: 10
-%}

{{ 'gebetswerk-product.css' | asset_url | stylesheet_tag }}

{%- assign raw_p1 = section.settings.price_name1 | plus: 0 -%}
{%- assign raw_p2 = section.settings.price_name2 | plus: 0 -%}

{%- if raw_p1 < 100 -%}{%- assign price_name1 = raw_p1 | times: 100 -%}{%- else -%}{%- assign price_name1 = raw_p1 -%}{%- endif -%}
{%- if raw_p2 < 100 -%}{%- assign price_name2 = raw_p2 | times: 100 -%}{%- else -%}{%- assign price_name2 = raw_p2 -%}{%- endif -%}

{%- comment -%} Pass all data to JS {%- endcomment -%}
<script>
  window.GW_VARIANTS            = {{ product.variants | json }};
  window.GW_COUNTDOWN_HOUR      = {{ section.settings.countdown_cutoff_hour | default: 17 }};

  {%- assign symbol_blocks = section.blocks | where: 'type', 'symbol' -%}
  window.GW_SYMBOLS = [
    {%- if symbol_blocks.size > 0 -%}
      {%- for block in symbol_blocks -%}
        { id: {{ block.settings.symbol_id | json }}, label: {{ block.settings.label | json }}, icon: {{ block.settings.icon | json }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    {%- else -%}
      { id: 'none', label: 'Keins', icon: '—' },
      { id: 'moon', label: 'Halbmond', icon: '☾' },
      { id: 'heart', label: 'Herz', icon: '♥' },
      { id: 'infinity', label: 'Unendlich', icon: '∞' }
    {%- endif -%}
  ];

  {%- comment -%} Personalization pricing — hardcoded in cents {%- endcomment -%}
  window.GW_PRICES = {
    name1:    {{ price_name1 | default: 1000 }},
    name2:    {{ price_name2 | default: 1500 }},
    symbol:   {{ section.settings.price_symbol   | default: 400 }}
  };

  {%- comment -%} Add-on variant IDs — separate Shopify line items for correct cart total {%- endcomment -%}
  window.GW_ADDON_VARIANTS = {
    name1:    {{ section.settings.addon_name1_variant_id    | default: 0 }},
    name2:    {{ section.settings.addon_name2_variant_id    | default: 0 }},
    symbol:   {{ section.settings.addon_symbol_variant_id   | default: 0 }}
  };
</script>

{%- comment -%} SEO: BreadcrumbList + Product schema {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":"Gebetsteppiche","item":"{{ shop.url }}/collections/all"},
    {"@type":"ListItem","position":3,"name":{{ product.title | json }},"item":"{{ shop.url }}{{ product.url }}"}
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "image": {{ product.featured_image | image_url: width: 1200 | json }},
  "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
  "sku": {{ current_variant.sku | json }},
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "EUR",
    "price": {{ current_variant.price | divided_by: 100.0 }},
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  },
  {%- assign ld_count = product.metafields.reviews.rating_count -%}
  {%- if ld_count and ld_count > 0 -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value.rating | round: 2 }}",
    "reviewCount": "{{ ld_count }}"
  }
  {%- else -%}
  "category": "Religious Items"
  {%- endif -%}
}
</script>

<div class="gw-product-page">
  <div class="gw-product-page__inner">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="gw-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 10l7-7 7 7"/><path d="M5 8v9h4v-5h2v5h4V8"/></svg> Home</a>
      <span class="gw-breadcrumb__sep">/</span>
      <a href="{{ routes.all_products_collection_url }}">Gebetsteppiche</a>
      <span class="gw-breadcrumb__sep">/</span>
      <span>{{ product.title }}</span>
    </nav>

    <div class="gw-product-layout">

      {%- comment -%} ══ GALLERY ══ {%- endcomment -%}
      <div class="gw-gallery">
        <div class="gw-gallery__main">
          {%- assign main_img = current_variant.featured_image | default: product.featured_image -%}
          <img id="gw-gallery-main-img"
            src="{{ main_img | image_url: width: 1200 }}"
            alt="{{ main_img.alt | default: product.title | escape }}"
            width="1200" height="{{ 1200 | divided_by: main_img.aspect_ratio | round }}" loading="eager" fetchpriority="high"
          >

        </div>

        <div class="gw-gallery__thumbs">
          {%- if product.media.size > 0 -%}
            {%- for media in product.media limit: 4 -%}
              <button class="gw-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ media.preview_image | image_url: width: 800 }}" aria-label="Bild {{ forloop.index }}">
                <img src="{{ media.preview_image | image_url: width: 200 }}" alt="{{ media.alt | default: product.title | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: media.preview_image.aspect_ratio | round }}">
              </button>
            {%- endfor -%}
          {%- else -%}
            {%- assign fallback_thumbs = 'product-main.jpg,product-thumb1.jpg,product-thumb2.jpg,product-thumb3.jpg' | split: ',' -%}
            {%- for img in fallback_thumbs -%}
              <button class="gw-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-src="{{ img | asset_url }}" aria-label="Bild {{ forloop.index }}">
                <img src="{{ img | asset_url }}" alt="Produktbild" loading="lazy" width="200" height="200">
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} ══ SIDEBAR ══ {%- endcomment -%}
      <aside class="gw-product-sidebar">

        <span class="gw-product__chip">
          <svg viewBox="0 0 20 20"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
          {{ section.settings.badge_text }}
        </span>

        <h1 class="gw-product__title">{{ product.title }}</h1>

        {%- assign jm_rating = product.metafields.reviews.rating.value -%}
        {%- assign jm_count = product.metafields.reviews.rating_count -%}
        {%- if jm_count and jm_count > 0 -%}
          <div class="gw-product__rating">
            <div class="gw-product__rating-fallback">
              {% render 'gw-rating-stars', product: product, show_count: false %}
              <a href="#gw-reviews" class="gw-product__rating-count">{{ jm_rating.rating | round: 1 | replace: '.', ',' }} · {{ jm_count }} Bewertung{% if jm_count != 1 %}en{% endif %}</a>
            </div>
          </div>
        {%- endif -%}

        <div class="gw-product__price-row">
          <span id="gw-price" class="gw-product__price">{{ current_variant.price | money }}</span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="gw-product__price-original">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Real inventory from Shopify {%- endcomment -%}
        {%- if current_variant.available -%}
          {%- if inv > 0 and inv <= inv_threshold -%}
            <div class="gw-product__urgency" id="gw-urgency">
              <span class="gw-product__urgency-dot"></span>
              <span id="gw-urgency-text">Nur noch {{ inv }} Stück verfügbar</span>
            </div>
          {%- endif -%}
        {%- else -%}
          <div class="gw-product__urgency" id="gw-urgency" style="background:#fff1f1;color:#b91c1c;">
            <span class="gw-product__urgency-dot"></span>
            <span id="gw-urgency-text">Ausverkauft</span>
          </div>
        {%- endif -%}


        <div class="gw-product__countdown">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Bestelle in <strong id="gw-countdown-time">--:--:--</strong> für Versand morgen
        </div>

        {%- comment -%} ══ PRODUCT FORM ══ {%- endcomment -%}
        {%- form 'product', product, id: 'gw-product-form', novalidate: 'novalidate' -%}

          <input type="hidden" name="id"       id="gw-variant-id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" id="gw-qty-input"   value="1">

          {%- comment -%} LINE ITEM PROPERTIES — saved with every Shopify order, visible in admin + emails {%- endcomment -%}
          <input type="hidden" name="properties[Name 1]"           id="prop-name1"      value="">
          <input type="hidden" name="properties[Name 2]"           id="prop-name2"      value="">
          <input type="hidden" name="properties[Schriftfarbe]"     id="prop-thread"     value="">
          <input type="hidden" name="properties[Symbol]"           id="prop-symbol"     value="">
          <input type="hidden" name="properties[Symbolposition]"   id="prop-symbol-pos" value="">
          <input type="hidden" name="properties[Gebetskette]"      id="prop-bead"       value="">
          {%- comment -%} ─ Color variant picker ─ {%- endcomment -%}
          {%- if product.variants.size > 1 -%}
            <div style="margin-bottom:24px;">
              <p class="gw-product__section-label">Farbe <span id="gw-color-label">{{ current_variant.title }}</span></p>
              <div class="gw-product__colors">
                {%- for variant in product.variants -%}
                  <button type="button"
                    class="gw-color-swatch{% if variant.id == current_variant.id %} is-active{% endif %}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-color-name="{{ variant.title | escape }}"
                    data-variant-img="{{ variant.featured_image | image_url: width: 800 }}"
                    data-variant-inventory="{{ variant.inventory_quantity }}"
                    data-variant-available="{{ variant.available }}"
                    aria-label="{{ variant.title }}"
                    title="{{ variant.title }}"
                    {% unless variant.available %}style="opacity:0.4;" title="{{ variant.title }} – ausverkauft"{% endunless %}
                  >
                    {%- if variant.featured_image -%}
                      <img src="{{ variant.featured_image | image_url: width: 120 }}" alt="{{ variant.title | escape }}" loading="lazy" width="120" height="{{ 120 | divided_by: variant.featured_image.aspect_ratio | round }}">
                    {%- else -%}
                      <img src="{{ 'mat-white.jpg' | asset_url }}" alt="{{ variant.title | escape }}" loading="lazy" width="120" height="120">
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} ─ Personalization box ─ {%- endcomment -%}
          <div class="gw-personalize-box">
            <label class="gw-personalize-toggle">
              <input type="checkbox" id="gw-personalize-toggle" checked>
              <div class="gw-personalize-toggle-text">
                <p>{{ section.settings.personalize_title | default: 'Gebetsteppich personalisieren?' }}</p>
                <p>{{ section.settings.personalize_desc | default: 'Mit gestickten Namen wird dein Geschenk einzigartig.' }} (+{{ section.settings.price_name1 | default: 1000 | money_without_currency }}€)</p>
              </div>
            </label>

            <div id="gw-personalize-fields" class="gw-personalize-fields">

              <div class="gw-form-field">
                <label class="gw-form-label" for="gw-name1-input">Name 1 * <span style="font-weight:400;color:var(--gw-muted)">(max. 11 Zeichen)</span></label>
                <div class="gw-form-input-wrap">
                  <input type="text" id="gw-name1-input" class="gw-form-input" placeholder="z. B. Amina" maxlength="11" autocomplete="off">
                  <span id="gw-name1-count" class="gw-char-count">0/11</span>
                </div>
              </div>

              <div class="gw-option-toggle">
                <label><input type="checkbox" id="gw-twonames-toggle"> Zweiten Namen hinzufügen</label>
                <span class="gw-option-price">+ €15,00</span>
              </div>

              <div id="gw-name2-section" class="gw-form-field" hidden>
                <label class="gw-form-label" for="gw-name2-input">Name 2</label>
                <div class="gw-form-input-wrap">
                  <input type="text" id="gw-name2-input" class="gw-form-input" placeholder="z. B. Yusuf" maxlength="11" autocomplete="off">
                  <span id="gw-name2-count" class="gw-char-count">0/11</span>
                </div>
              </div>

              {%- comment -%} Thread colors from blocks {%- endcomment -%}
              {%- assign thread_blocks = section.blocks | where: 'type', 'thread_color' -%}
              {%- if thread_blocks.size > 0 -%}
                <div class="gw-form-field">
                  <p class="gw-form-label">Schriftfarbe</p>
                  <div class="gw-thread-grid">
                    {%- for block in thread_blocks -%}
                      <button type="button"
                        class="gw-thread-swatch{% if forloop.first %} is-active{% endif %}"
                        data-thread="{{ block.settings.id }}"
                        data-hex="{{ block.settings.hex }}"
                        data-label="{{ block.settings.name | escape }}"
                        title="{{ block.settings.name }}"
                        aria-label="{{ block.settings.name }}"
                        {{ block.shopify_attributes }}
                      >
                        <span class="gw-thread-swatch__dot" style="background:{{ block.settings.hex }};"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- else -%}
                {%- comment -%} Fallback thread colors {%- endcomment -%}
                <div class="gw-form-field">
                  <p class="gw-form-label">Schriftfarbe</p>
                  <div class="gw-thread-grid">
                    {%- assign default_threads = 'gold|Gold|#c9a24a,silver|Silber|#c8c8cc,white|Weiß|#f5f1e6,black|Schwarz|#1a1a1a,brown|Braun|#7a5230' | split: ',' -%}
                    {%- for tc in default_threads -%}
                      {%- assign p = tc | split: '|' -%}
                      <button type="button" class="gw-thread-swatch{% if forloop.first %} is-active{% endif %}" data-thread="{{ p[0] }}" data-hex="{{ p[2] }}" data-label="{{ p[1] }}" title="{{ p[1] }}" aria-label="{{ p[1] }}">
                        <span class="gw-thread-swatch__dot" style="background:{{ p[2] }};"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}

              {%- comment -%} Symbols — from blocks or fallback {%- endcomment -%}
              {%- assign symbol_blocks = section.blocks | where: 'type', 'symbol' -%}
              <div class="gw-form-field">
                <div class="gw-option-toggle" style="margin-bottom:8px;">
                  <p class="gw-form-label" style="margin-bottom:0;">Symbol</p>
                  <span class="gw-option-price" id="gw-symbol-price-tag" hidden>+{{ section.settings.price_symbol | default: 400 | money_without_currency }}€</span>
                </div>
                <div class="gw-symbol-grid">
                  {%- if symbol_blocks.size > 0 -%}
                    {%- for block in symbol_blocks -%}
                      <button type="button" class="gw-symbol-btn{% if forloop.first %} is-active{% endif %}"
                        data-symbol="{{ block.settings.symbol_id }}"
                        {{ block.shopify_attributes }}>
                        <span class="gw-symbol-btn__icon" style="color:var(--gw-gold)">{{ block.settings.icon }}</span>
                        <span class="gw-symbol-btn__label">{{ block.settings.label }}</span>
                      </button>
                    {%- endfor -%}
                  {%- else -%}
                    {%- assign fallback_symbols = 'none|Keins|—,moon|Halbmond|☾,heart|Herz|♥,infinity|Unendlich|∞' | split: ',' -%}
                    {%- for sym in fallback_symbols -%}
                      {%- assign sp = sym | split: '|' -%}
                      <button type="button" class="gw-symbol-btn{% if forloop.first %} is-active{% endif %}" data-symbol="{{ sp[0] }}">
                        <span class="gw-symbol-btn__icon" style="color:var(--gw-gold)">{{ sp[2] }}</span>
                        <span class="gw-symbol-btn__label">{{ sp[1] }}</span>
                      </button>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>

              <div id="gw-sympos-section" class="gw-form-field" hidden>
                <p class="gw-form-label">Position des Symbols</p>
                <div class="gw-sympos-grid">
                  <button type="button" class="gw-sympos-btn is-active" data-sympos="left">
                    <span>Links</span>
                    <span class="gw-sympos-preview" data-dir="row">
                      <span style="color:var(--gw-gold);font-size:13px;">☾</span>
                      <span style="font-family:'Fraunces',serif;font-style:italic;font-size:11px;color:var(--gw-gold);">Aa</span>
                    </span>
                  </button>
                  <button type="button" class="gw-sympos-btn" data-sympos="right">
                    <span>Rechts</span>
                    <span class="gw-sympos-preview" data-dir="row-rev">
                      <span style="color:var(--gw-gold);font-size:13px;">☾</span>
                      <span style="font-family:'Fraunces',serif;font-style:italic;font-size:11px;color:var(--gw-gold);">Aa</span>
                    </span>
                  </button>
                  <button type="button" class="gw-sympos-btn" id="gw-sympos-between" data-sympos="between" hidden>
                    <span>Zwischen den Namen</span>
                    <span class="gw-sympos-preview" data-dir="row">
                      <span style="font-family:'Fraunces',serif;font-style:italic;font-size:9px;color:var(--gw-gold);">Aa</span>
                      <span style="color:var(--gw-gold);font-size:11px;">☾</span>
                      <span style="font-family:'Fraunces',serif;font-style:italic;font-size:9px;color:var(--gw-gold);">Bb</span>
                    </span>
                  </button>
                </div>
              </div>

            </div>
          </div>

          {%- comment -%} ══ DYNAMISCHE ADD-ONS ══ {%- endcomment -%}
          {%- assign rendered_choice_groups = '' -%}
          {%- for block in section.blocks -%}

            {%- comment -%} ── Textfeld ── {%- endcomment -%}
            {%- if block.type == 'opt_text' -%}
              <div class="gw-form-field" {{ block.shopify_attributes }}>
                <label class="gw-form-label" for="addon-{{ block.id }}">
                  {{ block.settings.label }}
                  {%- if block.settings.surcharge_cents > 0 -%}<span class="gw-option-price" style="margin-left:4px;font-size:12px;">(+{{ block.settings.surcharge_cents | money_without_currency }}€)</span>{%- endif -%}
                  {%- if block.settings.required -%}<span style="color:var(--gw-gold)"> *</span>{%- endif -%}
                </label>
                <div class="gw-form-input-wrap">
                  <input type="text" id="addon-{{ block.id }}" class="gw-form-input"
                    placeholder="{{ block.settings.placeholder | escape }}"
                    {%- if block.settings.max_chars > 0 %}maxlength="{{ block.settings.max_chars }}"{%- endif %}
                    data-addon="text" data-block="{{ block.id }}"
                    data-fkey="{{ block.settings.field_key | escape }}"
                    data-surcharge="{{ block.settings.surcharge_cents | default: 0 }}"
                    data-variant="{{ block.settings.addon_variant_id | default: 0 }}"
                    data-required="{{ block.settings.required }}"
                    autocomplete="off">
                  {%- if block.settings.show_char_counter and block.settings.max_chars > 0 -%}
                    <span class="gw-char-count" data-counter="{{ block.id }}">0/{{ block.settings.max_chars }}</span>
                  {%- endif -%}
                </div>
              </div>

            {%- comment -%} ── Checkbox ── {%- endcomment -%}
            {%- elsif block.type == 'opt_checkbox' -%}
              <label class="gw-giftwrap-row" {{ block.shopify_attributes }}>
                <span>
                  {%- if block.settings.icon != blank -%}{{ block.settings.icon }} {%- endif -%}
                  {{ block.settings.label }}
                  {%- if block.settings.description != blank -%}
                    <span style="display:block;font-size:12px;color:var(--gw-muted);margin-top:2px;">{{ block.settings.description }}</span>
                  {%- endif -%}
                </span>
                <span class="gw-giftwrap-right">
                  {%- if block.settings.surcharge_cents > 0 -%}<span class="gw-giftwrap-price">+{{ block.settings.surcharge_cents | money }}</span>{%- endif -%}
                  <input type="checkbox" id="addon-{{ block.id }}"
                    data-addon="checkbox" data-block="{{ block.id }}"
                    data-fkey="{{ block.settings.field_key | escape }}"
                    data-surcharge="{{ block.settings.surcharge_cents | default: 0 }}"
                    data-variant="{{ block.settings.addon_variant_id | default: 0 }}"
                    {% if block.settings.default_checked %}checked{% endif %}>
                </span>
              </label>

            {%- comment -%} ── Auswahl-Gruppe ── {%- endcomment -%}
            {%- elsif block.type == 'opt_choice' -%}
              {%- assign gid = block.settings.group_id -%}
              {%- unless rendered_choice_groups contains gid -%}
                {%- assign rendered_choice_groups = rendered_choice_groups | append: gid | append: '§' -%}
                {%- assign dt = block.settings.display_type | default: 'buttons' -%}
                {%- assign glabel = block.settings.group_label | default: gid -%}
                {%- assign fkey = block.settings.field_key | default: glabel -%}
                <div class="gw-form-field" data-addon="choice-group" data-gid="{{ gid }}" data-fkey="{{ fkey | escape }}" {{ block.shopify_attributes }}>
                  <p class="gw-form-label">{{ glabel }}</p>
                  {%- if dt == 'dropdown' -%}
                    <select class="gw-form-input" data-addon="choice-select" data-gid="{{ gid }}">
                      {%- for inner in section.blocks -%}
                        {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                          <option value="{{ inner.settings.choice_value | escape }}"
                            data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                            data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                            {% if inner.settings.is_default %}selected{% endif %}>
                            {{ inner.settings.choice_label }}{% if inner.settings.surcharge_cents > 0 %} (+{{ inner.settings.surcharge_cents | money_without_currency }}€){% endif %}
                          </option>
                        {%- endif -%}
                      {%- endfor -%}
                    </select>
                  {%- elsif dt == 'swatches' -%}
                    <div class="gw-thread-grid">
                      {%- for inner in section.blocks -%}
                        {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                          <button type="button"
                            class="gw-thread-swatch{% if inner.settings.is_default %} is-active{% endif %}"
                            data-addon="choice-btn" data-gid="{{ gid }}"
                            data-val="{{ inner.settings.choice_value | escape }}"
                            data-lbl="{{ inner.settings.choice_label | escape }}"
                            data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                            data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                            title="{{ inner.settings.choice_label }}" aria-label="{{ inner.settings.choice_label }}"
                            {{ inner.shopify_attributes }}>
                            <span class="gw-thread-swatch__dot" style="background:{{ inner.settings.hex_color | default: '#ccc' }};"></span>
                          </button>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- elsif dt == 'images' -%}
                    <div class="gw-beads-grid">
                      {%- for inner in section.blocks -%}
                        {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                          <button type="button"
                            class="gw-bead-btn{% if inner.settings.is_default %} is-active{% endif %}"
                            data-addon="choice-btn" data-gid="{{ gid }}"
                            data-val="{{ inner.settings.choice_value | escape }}"
                            data-lbl="{{ inner.settings.choice_label | escape }}"
                            data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                            data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                            {{ inner.shopify_attributes }}>
                            <div class="gw-bead-btn__img">
                              {%- if inner.settings.choice_image != blank -%}
                                <img src="{{ inner.settings.choice_image | image_url: width: 200 }}" alt="{{ inner.settings.choice_label | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: inner.settings.choice_image.aspect_ratio | round }}">
                              {%- elsif inner.settings.hex_color != blank -%}
                                <div style="width:100%;height:100%;background:{{ inner.settings.hex_color }};border-radius:4px;"></div>
                              {%- else -%}
                                <div class="gw-bead-btn__none">{{ inner.settings.choice_label | slice: 0 }}</div>
                              {%- endif -%}
                            </div>
                            <div class="gw-bead-btn__info">
                              <span class="gw-bead-btn__name">{{ inner.settings.choice_label }}</span>
                              <span class="gw-bead-btn__price">{% if inner.settings.surcharge_cents > 0 %}+{{ inner.settings.surcharge_cents | money_without_currency }}€{% else %}—{% endif %}</span>
                            </div>
                          </button>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- else -%}
                    <div class="gw-sympos-grid" style="flex-wrap:wrap;gap:8px;">
                      {%- for inner in section.blocks -%}
                        {%- if inner.type == 'opt_choice' and inner.settings.group_id == gid -%}
                          <button type="button"
                            class="gw-sympos-btn{% if inner.settings.is_default %} is-active{% endif %}"
                            data-addon="choice-btn" data-gid="{{ gid }}"
                            data-val="{{ inner.settings.choice_value | escape }}"
                            data-lbl="{{ inner.settings.choice_label | escape }}"
                            data-surcharge="{{ inner.settings.surcharge_cents | default: 0 }}"
                            data-variant="{{ inner.settings.addon_variant_id | default: 0 }}"
                            {{ inner.shopify_attributes }}>
                            {{ inner.settings.choice_label }}
                            {%- if inner.settings.surcharge_cents > 0 -%}<span style="font-size:11px;opacity:0.7;"> +{{ inner.settings.surcharge_cents | money_without_currency }}€</span>{%- endif -%}
                          </button>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endunless -%}

            {%- comment -%} ── Produkt-Auswahl ── {%- endcomment -%}
            {%- elsif block.type == 'opt_product' -%}
              {%- assign linked_product = all_products[block.settings.product] -%}
              {%- if linked_product != blank -%}
                {%- assign opt_dt = block.settings.display_type | default: 'image_grid' -%}
                <div class="gw-form-field" {{ block.shopify_attributes }}>
                  <p class="gw-product__section-label">{{ block.settings.label }} <span>Optional</span></p>
                  {%- if opt_dt == 'dropdown' -%}
                    <select class="gw-form-input"
                      data-addon="product-select" data-block="{{ block.id }}"
                      data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                      data-separate="{{ block.settings.separate_line_item }}">
                      {%- if block.settings.include_none -%}
                        <option value="" data-price="0" data-variant="0">{{ block.settings.none_label | default: 'Keine' }}</option>
                      {%- endif -%}
                      {%- for v in linked_product.variants -%}
                        <option value="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}">
                          {{ v.title }} (+{{ v.price | money_without_currency }}€)
                        </option>
                      {%- endfor -%}
                    </select>
                  {%- elsif opt_dt == 'list' -%}
                    <div style="display:flex;flex-direction:column;gap:8px;">
                      {%- if block.settings.include_none -%}
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                          <input type="radio" name="opt-p-{{ block.id }}" value="" data-price="0" data-variant="0"
                            data-addon="product-radio" data-block="{{ block.id }}"
                            data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                            data-separate="{{ block.settings.separate_line_item }}" checked>
                          {{ block.settings.none_label | default: 'Keine' }}
                        </label>
                      {%- endif -%}
                      {%- for v in linked_product.variants -%}
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;">
                          <input type="radio" name="opt-p-{{ block.id }}" value="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}"
                            data-addon="product-radio" data-block="{{ block.id }}"
                            data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                            data-separate="{{ block.settings.separate_line_item }}">
                          {{ v.title }} (+{{ v.price | money_without_currency }}€)
                        </label>
                      {%- endfor -%}
                    </div>
                  {%- else -%}
                    <div class="gw-beads-grid">
                      {%- if block.settings.include_none -%}
                        <button type="button" class="gw-bead-btn is-active"
                          data-addon="product-card" data-block="{{ block.id }}"
                          data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                          data-separate="{{ block.settings.separate_line_item }}"
                          data-val="" data-price="0" data-variant="0">
                          <div class="gw-bead-btn__img"><div class="gw-bead-btn__none">{{ block.settings.none_label | default: 'Keine' | slice: 0 }}</div></div>
                          <div class="gw-bead-btn__info">
                            <span class="gw-bead-btn__name">{{ block.settings.none_label | default: 'Keine' }}</span>
                            <span class="gw-bead-btn__price">—</span>
                          </div>
                        </button>
                      {%- endif -%}
                      {%- for v in linked_product.variants -%}
                        <button type="button" class="gw-bead-btn"
                          data-addon="product-card" data-block="{{ block.id }}"
                          data-fkey="{{ block.settings.field_key | default: block.settings.label | escape }}"
                          data-separate="{{ block.settings.separate_line_item }}"
                          data-val="{{ v.title | escape }}" data-price="{{ v.price }}" data-variant="{{ v.id }}">
                          <div class="gw-bead-btn__img">
                            {%- if v.featured_image -%}
                              <img src="{{ v.featured_image | image_url: width: 200 }}" alt="{{ v.title | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: v.featured_image.aspect_ratio | round }}">
                            {%- elsif linked_product.featured_image -%}
                              <img src="{{ linked_product.featured_image | image_url: width: 200 }}" alt="{{ v.title | escape }}" loading="lazy" width="200" height="{{ 200 | divided_by: linked_product.featured_image.aspect_ratio | round }}">
                            {%- else -%}
                              <div class="gw-bead-btn__none">?</div>
                            {%- endif -%}
                          </div>
                          <div class="gw-bead-btn__info">
                            <span class="gw-bead-btn__name">{{ v.title }}</span>
                            <span class="gw-bead-btn__price">+{{ v.price | money_without_currency }}€</span>
                          </div>
                        </button>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}

            {%- endif -%}
          {%- endfor -%}

          {%- comment -%} ─ Order confirmation summary ─ {%- endcomment -%}
          <div id="gw-order-summary" class="gw-order-summary" hidden>
            <p class="gw-order-summary__label">Deine Bestellung:</p>
            <ul id="gw-order-summary-list" class="gw-order-summary__list"></ul>
          </div>

          {%- comment -%} ─ Qty + ATC ─ {%- endcomment -%}
          <div class="gw-product__actions">
            <div class="gw-qty">
              <button type="button" id="gw-qty-minus" class="gw-qty__btn" aria-label="Weniger">−</button>
              <span id="gw-qty-val" class="gw-qty__val">1</span>
              <button type="button" id="gw-qty-plus"  class="gw-qty__btn" aria-label="Mehr">+</button>
            </div>
            <button type="button" id="gw-atc-btn" class="gw-add-to-cart"{% unless current_variant.available %} disabled{% endunless %}>
              {% if current_variant.available %}In den Warenkorb · {{ current_variant.price | money }}{% else %}Ausverkauft{% endif %}
            </button>
          </div>

          {%- comment -%} ─ Zweiten Teppich hinzufügen: legt den aktuellen in den Warenkorb,
              leert das Formular und scrollt hoch zum Namensfeld ─ {%- endcomment -%}
          <button type="button" id="gw-reset-btn" class="gw-reset-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Weiteren Teppich personalisieren
          </button>

          {%- comment -%}
            Kein payment_button — Dynamic Checkout (Klarna, Shop Pay usw.) würde die
            Gebetskette und alle Add-ons überspringen, da er nicht durch unsere Cart API läuft.
            Stattdessen: eigener "Jetzt kaufen"-Button → addToCart() → /checkout
          {%- endcomment -%}
          {%- if current_variant.available -%}
            <button type="button" id="gw-buy-now-btn" class="gw-buy-now-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>
              Jetzt kaufen
            </button>
          {%- endif -%}

          {%- comment -%} Trust badges — from blocks {%- endcomment -%}
          {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
          {%- if trust_blocks.size > 0 -%}
            <div class="gw-trust-badges">
              {%- for block in trust_blocks -%}
                <div class="gw-trust-badge" {{ block.shopify_attributes }}>
                  {%- case block.settings.icon -%}
                    {%- when 'lock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                    {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {%- endcase -%}
                  <span>{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        {%- endform -%}

        {%- comment -%} ─ Shipping info ─ {%- endcomment -%}
        {%- if section.settings.shipping_row1 != blank or section.settings.shipping_row2 != blank -%}
          <div class="gw-product__shipping">
            {%- if section.settings.shipping_row1 != blank -%}
              <div class="gw-product__shipping-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                <span>{{ section.settings.shipping_row1 }}</span>
              </div>
            {%- endif -%}
            {%- if section.settings.shipping_row2 != blank -%}
              <div class="gw-product__shipping-row">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                <span>{{ section.settings.shipping_row2 }}</span>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- comment -%} ─ Accordions: Produktbeschreibung immer oben, dann Blocks ─ {%- endcomment -%}
        {%- assign accordion_blocks = section.blocks | where: 'type', 'accordion' -%}
        {%- if product.description != blank or accordion_blocks.size > 0 -%}
          <div class="gw-product-accordion">
            {%- if product.description != blank -%}
              <details>
                <summary>Beschreibung & Material</summary>
                <div class="gw-product-accordion__body">{{ product.description }}</div>
              </details>
            {%- endif -%}
            {%- for block in accordion_blocks -%}
              <details {{ block.shopify_attributes }}>
                <summary>{{ block.settings.title }}</summary>
                <div class="gw-product-accordion__body">{{ block.settings.content }}</div>
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </aside>
    </div>
  </div>
</div>

{%- comment -%} Sticky mobile CTA {%- endcomment -%}
<div id="gw-sticky-atc" class="gw-sticky-atc" hidden>
  <div class="gw-sticky-atc__inner">
    <div>
      <p class="gw-sticky-atc__title">{{ product.title | truncate: 30 }}</p>
      <p id="gw-sticky-price" class="gw-sticky-atc__price">{{ current_variant.price | money }}</p>
    </div>
    <button type="button" id="gw-sticky-atc-btn" class="gw-add-to-cart" style="flex-shrink:0;height:44px;padding:0 20px;font-size:13px;">
      In den Warenkorb
    </button>
  </div>
</div>

<script src="{{ 'gebetswerk-product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Produktseite",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "✏️ Personalisierungsbox"
    },
    {
      "type": "text",
      "id": "personalize_title",
      "label": "Checkbox-Titel",
      "default": "Gebetsteppich personalisieren?",
      "info": "Große Schrift in der Personalisierungs-Checkbox"
    },
    {
      "type": "text",
      "id": "personalize_desc",
      "label": "Beschreibungstext",
      "default": "Mit gestickten Namen wird dein Geschenk einzigartig.",
      "info": "Der Aufpreis (+€10,00) wird automatisch aus den Preisen unten berechnet"
    },
    {
      "type": "header",
      "content": "⭐ Badge & Bewertung"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge-Text (über dem Produkttitel)",
      "default": "Personalisiertes Set",
      "info": "Kleines goldenes Label, z. B. 'Bestseller' oder 'Neu'"
    },
    {
      "type": "text",
      "id": "review_display",
      "label": "Bewertungstext",
      "default": "2.627 Bewertungen",
      "info": "Wird neben den Sternen als klickbarer Link angezeigt"
    },
    {
      "type": "number",
      "id": "review_count_number",
      "label": "Bewertungsanzahl (nur für Google-SEO)",
      "default": 2627,
      "info": "Muss mit dem Bewertungstext übereinstimmen"
    },
    {
      "type": "header",
      "content": "📦 Versand-Hinweise (unter dem Preis)"
    },
    {
      "type": "text",
      "id": "shipping_row1",
      "label": "Versandzeile 1",
      "default": "3–5 Werktage Lieferzeit · kostenlos ab 100 €",
      "info": "Erscheint mit LKW-Icon. Leer lassen → wird ausgeblendet"
    },
    {
      "type": "text",
      "id": "shipping_row2",
      "label": "Versandzeile 2",
      "default": "In edler Geschenkverpackung mit Goldschleife",
      "info": "Erscheint mit Paket-Icon. Leer lassen → wird ausgeblendet"
    },
    {
      "type": "header",
      "content": "⏰ Countdown-Timer"
    },
    {
      "type": "number",
      "id": "countdown_cutoff_hour",
      "label": "Versand-Cutoff-Uhrzeit (Stunde, 24h)",
      "default": 17,
      "info": "Timer zählt bis zu dieser Uhrzeit herunter, z. B. 17 = 17:00 Uhr"
    },
    {
      "type": "header",
      "content": "📊 Lagerbestand-Warnung"
    },
    {
      "type": "number",
      "id": "inventory_threshold",
      "label": "Warnung anzeigen ab (Stück)",
      "default": 10,
      "info": "Zeigt 'Nur noch X Stück verfügbar' wenn der Bestand darunter fällt"
    },
    {
      "type": "header",
      "content": "💰 Aufpreise für Personalisierung"
    },
    {
      "type": "paragraph",
      "content": "Preise in Cent eingeben: 1000 = €10,00 · 199 = €1,99"
    },
    {
      "type": "number",
      "id": "price_name1",
      "label": "Aufpreis: 1. Name",
      "default": 1000
    },
    {
      "type": "number",
      "id": "price_name2",
      "label": "Aufpreis: 2. Name (zusätzlich)",
      "default": 1500
    },
    {
      "type": "number",
      "id": "price_symbol",
      "label": "Aufpreis: Symbol",
      "default": 400
    },
    {
      "type": "header",
      "content": "🔧 Technisch: Aufpreis-Variant IDs"
    },
    {
      "type": "paragraph",
      "content": "Für korrekten Warenkorb-Gesamtpreis: Im Shopify Admin ein verstecktes Produkt 'Aufpreise' erstellen. Die Variant ID jeder Option hier eintragen."
    },
    {
      "type": "number",
      "id": "addon_name1_variant_id",
      "label": "Variant ID → 1. Name (€10)",
      "info": "Shopify Admin → Produkte → Aufpreise → Variante kopieren"
    },
    {
      "type": "number",
      "id": "addon_name2_variant_id",
      "label": "Variant ID → 2. Name (€15)"
    },
    {
      "type": "number",
      "id": "addon_symbol_variant_id",
      "label": "Variant ID → Symbol (€4,00)"
    }
  ],
  "blocks": [
    {
      "type": "thread_color",
      "name": "🎨 Schriftfarbe",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "id",
          "label": "ID (intern, keine Leerzeichen)",
          "default": "gold",
          "info": "Wird intern gespeichert, z. B. 'gold', 'silber', 'weiss'"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Anzeigename",
          "default": "Gold"
        },
        {
          "type": "text",
          "id": "hex",
          "label": "Farbe als Hex-Code",
          "default": "#c9a24a",
          "info": "z. B. #c9a24a für Gold. Hex-Codes findest du auf htmlcolorcodes.com"
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "✅ Vertrauens-Badge",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lock",   "label": "🔒 Schloss (Sicherheit)" },
            { "value": "shield", "label": "🛡️ Schild (Garantie)" },
            { "value": "heart",  "label": "❤️ Herz (Handarbeit)" },
            { "value": "clock",  "label": "🕐 Uhr (Lieferzeit)" },
            { "value": "truck",  "label": "🚚 LKW (Versand)" },
            { "value": "star",   "label": "⭐ Stern (Bewertung)" },
            { "value": "gift",   "label": "🎁 Geschenk (Verpackung)" },
            { "value": "check",  "label": "✓ Haken (Bestätigung)" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "SSL-gesichert"
        }
      ]
    },
    {
      "type": "opt_text",
      "name": "📝 Textfeld",
      "settings": [
        { "type": "text",     "id": "label",         "label": "Bezeichnung",                    "default": "Zusatz-Name" },
        { "type": "text",     "id": "field_key",      "label": "Schlüssel (erscheint in Bestellung)", "default": "Zusatz-Name", "info": "z.B. 'Gravur', 'Name 3', 'Wunschtext'" },
        { "type": "text",     "id": "placeholder",    "label": "Platzhaltertext",                "default": "z.B. Amina" },
        { "type": "number",   "id": "max_chars",      "label": "Max. Zeichen (0 = unbegrenzt)",  "default": 20 },
        { "type": "checkbox", "id": "show_char_counter", "label": "Zeichenzähler anzeigen",      "default": true },
        { "type": "checkbox", "id": "required",       "label": "Pflichtfeld",                    "default": false },
        { "type": "number",   "id": "surcharge_cents","label": "Aufpreis in Cent (0 = kostenlos)","default": 0, "info": "Wird nur berechnet wenn das Feld ausgefüllt ist. 1000 = €10,00" },
