      "default": 2627
    },
    {
      "type": "header",
      "content": "Lagerbestand"
    },
    {
      "type": "number",
      "id": "inventory_threshold",
      "label": "Lagerbestand-Warnung ab (Stück)",
      "default": 10,
      "info": "Zeigt 'Nur noch X Stück' wenn Bestand darunter fällt"
    },
    {
      "type": "header",
      "content": "Preise (in Cent)"
    },
    {
      "type": "number",
      "id": "price_name1",
      "label": "Name 1 – Preis (Cent)",
      "default": 1000,
      "info": "1000 = €10,00"
    },
    {
      "type": "number",
      "id": "price_name2",
      "label": "Name 2 – Preis (Cent)",
      "default": 1500,
      "info": "1500 = €15,00"
    },
    {
      "type": "number",
      "id": "price_giftwrap",
      "label": "Geschenkverpackung – Preis (Cent)",
      "default": 199,
      "info": "199 = €1,99"
    },
    {
      "type": "number",
      "id": "price_symbol",
      "label": "Symbol – Preis (Cent)",
      "default": 400,
      "info": "400 = €4,00"
    },
    {
      "type": "header",
      "content": "Add-on Variant IDs (für korrekten Warenkorb-Preis)"
    },
    {
      "type": "paragraph",
      "content": "Erstelle im Shopify Admin ein verstecktes Produkt 'Aufpreise' und trage die Variant IDs hier ein. So zeigt der Warenkorb den echten Gesamtpreis."
    },
    {
      "type": "number",
      "id": "addon_name1_variant_id",
      "label": "Personalisierung Name 1 – Variant ID",
      "info": "Variant ID des €10-Aufpreis-Produkts"
    },
    {
      "type": "number",
      "id": "addon_name2_variant_id",
      "label": "2. Name – Variant ID",
      "info": "Variant ID des €15-Aufpreis-Produkts"
    },
    {
      "type": "number",
      "id": "addon_giftwrap_variant_id",
      "label": "Geschenkverpackung – Variant ID",
      "info": "Variant ID des €1,99-Aufpreis-Produkts"
    },
    {
      "type": "number",
      "id": "addon_symbol_variant_id",
      "label": "Symbol – Variant ID",
      "info": "Variant ID des €4,00-Aufpreis-Produkts"
    },
    {
      "type": "header",
      "content": "Gebetsketten"
    },
    {
      "type": "product",
      "id": "beads_product",
      "label": "Gebetsketten-Produkt",
      "info": "Die Varianten dieses Produkts werden als Optionen angezeigt. Preis und Lagerbestand kommen direkt aus dem Produkt."
    },
    {
      "type": "header",
      "content": "Texte"
    },
    {
      "type": "textarea",
      "id": "shipping_text",
