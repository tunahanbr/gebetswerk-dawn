{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign inv = current_variant.inventory_quantity | default: 0
  assign inv_threshold = section.settings.inventory_threshold | default: 10
  assign name_max = section.settings.name_max | default: 11 | at_least: 1
  assign atc_label = section.settings.atc_label | default: 'In den Warenkorb'
  assign soldout_label = section.settings.soldout_label | default: 'Ausverkauft'
  assign urgency_tpl = section.settings.urgency_text | default: 'Nur noch [Anzahl] Stück verfügbar'
-%}

{{ 'gebetswerk-product.css' | asset_url | stylesheet_tag }}

{%- liquid
  comment
    Aufpreise: Wenn das Aufpreise-Produkt verknüpft ist, gelten dessen echte
    Variantenpreise (= was Shopify tatsächlich berechnet). Die Zahlenfelder
    unten sind nur Fallback für die Anzeige, solange nichts verknüpft ist.
  endcomment
  assign price_name1 = section.settings.price_name1 | default: 1000 | plus: 0
  assign price_name2 = section.settings.price_name2 | default: 1500 | plus: 0
  assign price_symbol = section.settings.price_symbol | default: 400 | plus: 0
  assign addon_product = section.settings.addon_product
  if addon_product != blank
    for v in addon_product.variants
      if v.id == section.settings.addon_name1_variant_id
        assign price_name1 = v.price
      endif
      if v.id == section.settings.addon_name2_variant_id
        assign price_name2 = v.price
      endif
      if v.id == section.settings.addon_symbol_variant_id
        assign price_symbol = v.price
      endif
    endfor
  endif
-%}

{%- comment -%} Pass all data to JS {%- endcomment -%}
<script>
  window.GW_VARIANTS = [
    {%- for v in product.variants -%}
      { "id": {{ v.id }}, "price": {{ v.price }}, "available": {{ v.available }} }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ];

  {%- assign symbol_blocks = section.blocks | where: 'type', 'symbol' -%}
  window.GW_SYMBOLS = [
    {%- if symbol_blocks.size > 0 -%}
      {%- for block in symbol_blocks -%}
        { id: {{ block.settings.symbol_id | json }}, label: {{ block.settings.label | json }}, icon: {{ block.settings.icon | json }} }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    {%- else -%}
      { id: 'none', label: 'Keins', icon: '—' },
      { id: 'moon', label: 'Halbmond', icon: '☾' },
      { id: 'heart', label: 'Herz', icon: '♥' },
      { id: 'infinity', label: 'Unendlich', icon: '∞' }
    {%- endif -%}
  ];

  {%- comment -%} Personalization pricing in cents (aus Aufpreise-Produkt oder Fallback-Settings) {%- endcomment -%}
  window.GW_PRICES = {
    name1:    {{ price_name1 }},
    name2:    {{ price_name2 }},
    symbol:   {{ price_symbol }}
  };

  {%- comment -%} Add-on variant IDs — separate Shopify line items for correct cart total {%- endcomment -%}
  window.GW_ADDON_VARIANTS = {
    name1:    {{ section.settings.addon_name1_variant_id    | default: 0 }},
    name2:    {{ section.settings.addon_name2_variant_id    | default: 0 }},
    symbol:   {{ section.settings.addon_symbol_variant_id   | default: 0 }}
  };

  {%- comment -%} Beschriftungen für dynamische JS-Texte (Buttons, Verfügbarkeit) {%- endcomment -%}
  window.GW_STRINGS = {
    atc:     {{ atc_label | json }},
    soldOut: {{ soldout_label | json }},
    added:   {{ section.settings.added_label | default: '✓ Im Warenkorb' | json }},
    buyNow:  {{ section.settings.buy_now_label | default: 'Jetzt kaufen' | json }},
    urgency: {{ urgency_tpl | json }}
  };
</script>

{%- comment -%} SEO: BreadcrumbList + Product schema {%- endcomment -%}
{%- assign bc_collection = product.collections.first -%}
{%- if bc_collection -%}
  {%- assign bc_name = bc_collection.title -%}
  {%- assign bc_url = bc_collection.url -%}
{%- else -%}
  {%- assign bc_name = 'Gebetsteppiche' -%}
  {%- assign bc_url = routes.all_products_collection_url -%}
{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}"},
    {"@type":"ListItem","position":2,"name":{{ bc_name | json }},"item":"{{ shop.url }}{{ bc_url }}"},
    {"@type":"ListItem","position":3,"name":{{ product.title | json }},"item":"{{ shop.url }}{{ product.url }}"}
  ]
}
</script>
{%- assign price_valid_year = 'now' | date: '%Y' | plus: 1 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 300 | json }},
  "image": [
    {%- if product.images.size > 0 -%}
      {%- for image in product.images -%}
        {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    {%- else -%}
      {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
    {%- endif -%}
  ],
  "url": "{{ shop.url }}{{ product.url }}",
  "brand": { "@type": "Brand", "name": {{ shop.name | json }} },
  "sku": {{ current_variant.sku | json }},
  {%- if current_variant.sku != blank -%}"mpn": {{ current_variant.sku | json }},{%- endif -%}
  {%- assign gw_barcode = current_variant.barcode | strip -%}
  {%- assign gw_barcode_len = gw_barcode | size -%}
  {%- if gw_barcode_len == 8 or gw_barcode_len == 12 or gw_barcode_len == 13 or gw_barcode_len == 14 -%}"gtin": {{ gw_barcode | json }},{%- endif -%}
  "offers": {
    "@type": "Offer",
    "url": "{{ shop.url }}{{ product.url }}",
    "priceCurrency": "EUR",
    "price": {{ current_variant.price | divided_by: 100.0 }},
    "priceValidUntil": "{{ price_valid_year }}-12-31",
    "itemCondition": "https://schema.org/NewCondition",
    "availability": "{% if current_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "{{ shop.address.country_code | default: 'AT' }}",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 14,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  },
  {%- assign ld_count = product.metafields.reviews.rating_count | times: 1 -%}
  {%- if ld_count > 0 -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value.rating | round: 2 }}",
    "reviewCount": "{{ ld_count }}"
  }
  {%- else -%}
  "category": "Religious Items"
  {%- endif -%}
}
</script>

<div class="gw-product-page">
  <div class="gw-product-page__inner">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="gw-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 10l7-7 7 7"/><path d="M5 8v9h4v-5h2v5h4V8"/></svg> Home</a>
      <span class="gw-breadcrumb__sep">/</span>
      <a href="{{ bc_url }}">{{ bc_name }}</a>
      <span class="gw-breadcrumb__sep">/</span>
      <span>{{ product.title }}</span>
    </nav>

    <div class="gw-product-layout">

      {%- comment -%} ══ GALLERY — Swipe-Carousel ══ {%- endcomment -%}
      {%- assign main_img = current_variant.featured_image | default: product.featured_image -%}
      <div class="gw-gallery">
        <div class="gw-gallery__frame">
        <div class="gw-gallery__viewport" id="gw-gallery-viewport">

          {%- comment -%} Slide 1: Bild der ausgewählten Farbe (wird per JS bei Farbwechsel aktualisiert) {%- endcomment -%}
          <div class="gw-gallery__slide" data-variant-slide>
            {%- if main_img -%}
              <img id="gw-gallery-variant-img"
                src="{{ main_img | image_url: width: 1200 }}"
                srcset="{{ main_img | image_url: width: 400 }} 400w,
                        {{ main_img | image_url: width: 600 }} 600w,
                        {{ main_img | image_url: width: 800 }} 800w,
                        {{ main_img | image_url: width: 1200 }} 1200w,
                        {{ main_img | image_url: width: 1600 }} 1600w"
                sizes="(min-width: 990px) 50vw, 100vw"
                alt="{{ main_img.alt | default: product.title | escape }}"
                width="1200" height="{{ 1200 | divided_by: main_img.aspect_ratio | round }}" loading="eager" fetchpriority="high"
              >
            {%- else -%}
              {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-gallery__placeholder' }}
            {%- endif -%}
          </div>

          {%- comment -%} Weitere Bilder = restliche Medien des Produkts (ohne das Bild der aktuellen Farbe) {%- endcomment -%}
          {%- assign cur_media_id = current_variant.featured_media.id -%}
          {%- for media in product.media -%}
            {%- if cur_media_id and media.id == cur_media_id -%}{%- continue -%}{%- endif -%}
            <div class="gw-gallery__slide">
              <img
                src="{{ media.preview_image | image_url: width: 1200 }}"
                srcset="{{ media.preview_image | image_url: width: 400 }} 400w,
                        {{ media.preview_image | image_url: width: 600 }} 600w,
                        {{ media.preview_image | image_url: width: 800 }} 800w,
                        {{ media.preview_image | image_url: width: 1200 }} 1200w,
                        {{ media.preview_image | image_url: width: 1600 }} 1600w"
                sizes="(min-width: 990px) 50vw, 100vw"
                alt="{{ media.alt | default: product.title | escape }}"
                width="1200" height="{{ 1200 | divided_by: media.preview_image.aspect_ratio | round }}" loading="lazy"
              >
            </div>
          {%- endfor -%}
        </div>

          <button type="button" class="gw-gallery__arrow gw-gallery__arrow--prev" id="gw-gallery-prev" aria-label="Vorheriges Bild">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button type="button" class="gw-gallery__arrow gw-gallery__arrow--next" id="gw-gallery-next" aria-label="Nächstes Bild">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
          </button>
        </div>

        <div class="gw-gallery__dots" id="gw-gallery-dots"></div>
      </div>

      {%- comment -%} ══ SIDEBAR ══ {%- endcomment -%}
      <aside class="gw-product-sidebar">

        <span class="gw-product__chip">
          <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
          {{ section.settings.badge_text }}
        </span>

        <h1 class="gw-product__title">{{ product.title }}</h1>

        {%- if section.settings.subtitle != blank -%}
          <p class="gw-product__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- assign jm_rating = product.metafields.reviews.rating.value -%}
        {%- assign jm_count = product.metafields.reviews.rating_count | times: 1 -%}
        {%- if jm_count > 0 -%}
          <div class="gw-product__rating">
            <div class="gw-product__rating-fallback">
              {% render 'gw-rating-stars', product: product, show_count: false %}
              <a href="#gw-reviews" class="gw-product__rating-count">{{ jm_rating.rating | round: 1 | replace: '.', ',' }} · {{ jm_count }} Bewertung{% if jm_count != 1 %}en{% endif %}</a>
            </div>
          </div>
        {%- endif -%}

        <div class="gw-product__price-row">
          <span id="gw-price" class="gw-product__price" aria-live="polite">{{ current_variant.price | money }}</span>
          <span id="gw-price-original" class="gw-product__price-original"{% unless current_variant.compare_at_price > current_variant.price %} hidden{% endunless %}>{{ current_variant.compare_at_price | money }}</span>
        </div>

        {%- comment -%} Real inventory from Shopify — immer gerendert, JS blendet je Variante ein/aus {%- endcomment -%}
        {%- assign show_urgency = false -%}
        {%- if current_variant.available == false -%}
          {%- assign show_urgency = true -%}
        {%- elsif inv > 0 and inv <= inv_threshold -%}
          {%- assign show_urgency = true -%}
        {%- endif -%}
        <div class="gw-product__urgency" id="gw-urgency" data-threshold="{{ inv_threshold }}" aria-live="polite"{% unless show_urgency %} hidden{% endunless %}>
          <span class="gw-product__urgency-dot"></span>
          <span id="gw-urgency-text">{% if current_variant.available %}{{ urgency_tpl | replace: '[Anzahl]', inv }}{% else %}{{ soldout_label }}{% endif %}</span>
        </div>


        {%- comment -%} ══ PRODUCT FORM ══ {%- endcomment -%}
        {%- form 'product', product, id: 'gw-product-form', novalidate: 'novalidate' -%}

          <input type="hidden" name="id"       id="gw-variant-id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" id="gw-qty-input"   value="1">

          {%- comment -%} ─ Color variant picker ─ {%- endcomment -%}
          {%- if product.variants.size > 1 -%}
            <div class="gw-form-field">
              <p class="gw-product__section-label">{{ section.settings.label_color | default: 'Farbe' }} <span id="gw-color-label">{{ current_variant.title }}</span></p>
              <div class="gw-product__colors">
                {%- for variant in product.variants -%}
                  <button type="button"
                    class="gw-color-swatch{% if variant.id == current_variant.id %} is-active{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                    data-variant-id="{{ variant.id }}"
                    data-variant-price="{{ variant.price }}"
                    data-variant-compare="{{ variant.compare_at_price | default: 0 }}"
                    data-color-name="{{ variant.title | escape }}"
                    data-variant-img="{{ variant.featured_image | image_url: width: 1200 }}"
                    data-variant-inventory="{{ variant.inventory_quantity | at_most: 99 }}"
                    data-variant-available="{{ variant.available }}"
                    aria-pressed="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}"
                    aria-label="{{ variant.title | escape }}"
                    title="{% if variant.available %}{{ variant.title }}{% else %}{{ variant.title }} – ausverkauft{% endif %}"
                  >
                    {%- if variant.featured_image -%}
                      <img src="{{ variant.featured_image | image_url: width: 120 }}" alt="{{ variant.title | escape }}" loading="lazy" width="120" height="{{ 120 | divided_by: variant.featured_image.aspect_ratio | round }}">
                    {%- else -%}
                      <img src="{{ 'mat-white.jpg' | asset_url }}" alt="{{ variant.title | escape }}" loading="lazy" width="120" height="120">
                    {%- endif -%}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} ─ Personalization box ─ {%- endcomment -%}
          <div class="gw-personalize-box">
            <label class="gw-personalize-toggle">
              <input type="checkbox" id="gw-personalize-toggle" checked>
              <div class="gw-personalize-toggle-text">
                <p>{{ section.settings.personalize_title | default: 'Gebetsteppich personalisieren?' }}</p>
                <p>{{ section.settings.personalize_desc | default: 'Mit gestickten Namen wird dein Geschenk einzigartig.' }} (+{{ price_name1 | money }})</p>
              </div>
            </label>

            <div id="gw-personalize-fields" class="gw-personalize-fields">

              <div class="gw-form-field">
                <label class="gw-form-label" for="gw-name1-input">{{ section.settings.label_name1 | default: 'Name 1' }} * <span class="gw-form-label__hint">(max. {{ name_max }} Zeichen)</span></label>
                <div class="gw-form-input-wrap">
                  <input type="text" id="gw-name1-input" class="gw-form-input" placeholder="{{ section.settings.placeholder_name1 | default: 'z. B. Amina' | escape }}" maxlength="{{ name_max }}" autocomplete="off">
                  <span id="gw-name1-count" class="gw-char-count">0/{{ name_max }}</span>
                </div>
              </div>

              <div class="gw-option-toggle">
                <label><input type="checkbox" id="gw-twonames-toggle"> {{ section.settings.toggle_two_names | default: 'Zweiten Namen hinzufügen' }}</label>
                <span class="gw-option-price">+ {{ price_name2 | money }}</span>
              </div>

              <div id="gw-name2-section" class="gw-form-field" hidden>
                <label class="gw-form-label" for="gw-name2-input">{{ section.settings.label_name2 | default: 'Name 2' }}</label>
                <div class="gw-form-input-wrap">
                  <input type="text" id="gw-name2-input" class="gw-form-input" placeholder="{{ section.settings.placeholder_name2 | default: 'z. B. Yusuf' | escape }}" maxlength="{{ name_max }}" autocomplete="off">
                  <span id="gw-name2-count" class="gw-char-count">0/{{ name_max }}</span>
                </div>
              </div>

              {%- comment -%} Thread colors from blocks {%- endcomment -%}
              {%- assign thread_blocks = section.blocks | where: 'type', 'thread_color' -%}
              {%- if thread_blocks.size > 0 -%}
                <div class="gw-form-field">
                  <p class="gw-form-label gw-form-label--row">{{ section.settings.label_thread | default: 'Schriftfarbe' }}
                    <span class="gw-form-label__value"><span id="gw-thread-label-dot" class="gw-thread-label-dot"></span><span id="gw-thread-label"></span></span>
                  </p>
                  <div class="gw-thread-grid gw-thread-grid--row">
                    {%- for block in thread_blocks -%}
                      <button type="button"
                        class="gw-thread-swatch{% if forloop.first %} is-active{% endif %}"
                        data-thread="{{ block.settings.id | escape }}"
                        data-hex="{{ block.settings.hex | escape }}"
                        data-label="{{ block.settings.name | escape }}"
                        title="{{ block.settings.name | escape }}"
                        aria-label="{{ block.settings.name | escape }}"
                        aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                        {{ block.shopify_attributes }}
                      >
                        <span class="gw-thread-swatch__dot" style="background:{{ block.settings.hex | escape }};"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- else -%}
                {%- comment -%} Fallback thread colors {%- endcomment -%}
                <div class="gw-form-field">
                  <p class="gw-form-label gw-form-label--row">{{ section.settings.label_thread | default: 'Schriftfarbe' }}
                    <span class="gw-form-label__value"><span id="gw-thread-label-dot" class="gw-thread-label-dot"></span><span id="gw-thread-label"></span></span>
                  </p>
                  <div class="gw-thread-grid gw-thread-grid--row">
                    {%- assign default_threads = 'gold|Gold|#c9a24a,silver|Silber|#c8c8cc,white|Weiß|#f5f1e6,black|Schwarz|#1a1a1a,brown|Braun|#7a5230' | split: ',' -%}
                    {%- for tc in default_threads -%}
                      {%- assign p = tc | split: '|' -%}
                      <button type="button" class="gw-thread-swatch{% if forloop.first %} is-active{% endif %}" data-thread="{{ p[0] }}" data-hex="{{ p[2] }}" data-label="{{ p[1] }}" title="{{ p[1] }}" aria-label="{{ p[1] }}" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}">
                        <span class="gw-thread-swatch__dot" style="background:{{ p[2] }};"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}

              {%- comment -%} Symbols — from blocks or fallback {%- endcomment -%}
              <div class="gw-form-field">
                <div class="gw-option-toggle gw-option-toggle--compact">
                  <p class="gw-form-label gw-form-label--flush">{{ section.settings.label_symbol | default: 'Symbol' }}</p>
                  <span class="gw-option-price" id="gw-symbol-price-tag" hidden>+{{ price_symbol | money }}</span>
                </div>
                <div class="gw-symbol-grid">
                  {%- if symbol_blocks.size > 0 -%}
                    {%- for block in symbol_blocks -%}
                      <button type="button" class="gw-symbol-btn{% if forloop.first %} is-active{% endif %}"
                        data-symbol="{{ block.settings.symbol_id }}"
                        aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                        {{ block.shopify_attributes }}>
                        <span class="gw-symbol-btn__icon">{%- render 'gw-symbol-svg', id: block.settings.symbol_id, fallback: block.settings.icon -%}</span>
                        <span class="gw-symbol-btn__label">{{ block.settings.label }}</span>
                      </button>
                    {%- endfor -%}
                  {%- else -%}
                    {%- assign fallback_symbols = 'none|Keins|—,moon|Halbmond|☾,heart|Herz|♥,infinity|Unendlich|∞' | split: ',' -%}
                    {%- for sym in fallback_symbols -%}
                      {%- assign sp = sym | split: '|' -%}
                      <button type="button" class="gw-symbol-btn{% if forloop.first %} is-active{% endif %}" data-symbol="{{ sp[0] }}" aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}">
                        <span class="gw-symbol-btn__icon">{%- render 'gw-symbol-svg', id: sp[0], fallback: sp[2] -%}</span>
                        <span class="gw-symbol-btn__label">{{ sp[1] }}</span>
                      </button>
                    {%- endfor -%}
                  {%- endif -%}
                </div>
              </div>

              <div id="gw-sympos-section" class="gw-form-field" hidden>
                <p class="gw-form-label">{{ section.settings.label_sympos | default: 'Position des Symbols' }}</p>
                <div class="gw-sympos-grid">
                  <button type="button" class="gw-sympos-btn is-active" data-sympos="left" aria-pressed="true">
                    <span>Links</span>
                    <span class="gw-sympos-preview" data-dir="row">
                      <span class="gw-sympos-preview__symbol">{%- render 'gw-symbol-svg', id: 'moon' -%}</span>
                      <span class="gw-sympos-preview__name">Aa</span>
                    </span>
                  </button>
                  <button type="button" class="gw-sympos-btn" data-sympos="right" aria-pressed="false">
                    <span>Rechts</span>
                    <span class="gw-sympos-preview" data-dir="row-rev">
                      <span class="gw-sympos-preview__symbol">{%- render 'gw-symbol-svg', id: 'moon' -%}</span>
                      <span class="gw-sympos-preview__name">Aa</span>
                    </span>
                  </button>
                  <button type="button" class="gw-sympos-btn" id="gw-sympos-between" data-sympos="between" aria-pressed="false" hidden>
                    <span>Zwischen den Namen</span>
                    <span class="gw-sympos-preview" data-dir="row">
                      <span class="gw-sympos-preview__name gw-sympos-preview__name--small">Aa</span>
                      <span class="gw-sympos-preview__symbol gw-sympos-preview__symbol--small">{%- render 'gw-symbol-svg', id: 'moon' -%}</span>
                      <span class="gw-sympos-preview__name gw-sympos-preview__name--small">Bb</span>
                    </span>
                  </button>
                </div>
              </div>

            </div>
          </div>

          {% render 'gw-product-addons', section: section %}

          {%- comment -%} ─ Order confirmation summary ─ {%- endcomment -%}
          <div id="gw-order-summary" class="gw-order-summary" hidden>
            <p class="gw-order-summary__label">{{ section.settings.summary_label | default: 'Deine Bestellung:' }}</p>
            <ul id="gw-order-summary-list" class="gw-order-summary__list"></ul>
          </div>

          {%- comment -%} ─ Dynamische Lieferzeit (Standard / Express) ─ {%- endcomment -%}
          {%- if section.settings.delivery_show -%}
            {%- render 'gw-delivery-estimate',
              auto_express: true,
              prod_min: section.settings.delivery_prod_min,
              prod_max: section.settings.delivery_prod_max,
              ship_min: section.settings.delivery_ship_min,
              ship_max: section.settings.delivery_ship_max,
              exp_min: section.settings.delivery_exp_min,
              exp_max: section.settings.delivery_exp_max,
              cutoff_hour: section.settings.delivery_cutoff_hour,
              label: section.settings.delivery_label,
              standard_note: section.settings.delivery_standard_text,
              express_note: section.settings.delivery_express_text,
              express_hint: section.settings.delivery_express_hint
            -%}
          {%- endif -%}

          {%- comment -%} ─ Qty + ATC ─ {%- endcomment -%}
          <div class="gw-product__actions">
            <div class="gw-qty">
              <button type="button" id="gw-qty-minus" class="gw-qty__btn" aria-label="Weniger">−</button>
              <span id="gw-qty-val" class="gw-qty__val" role="status" aria-live="polite" aria-label="Menge">1</span>
              <button type="button" id="gw-qty-plus"  class="gw-qty__btn" aria-label="Mehr">+</button>
            </div>
            <button type="button" id="gw-atc-btn" class="gw-add-to-cart"{% unless current_variant.available %} disabled{% endunless %}>
              {% if current_variant.available %}{{ atc_label }} · {{ current_variant.price | money }}{% else %}{{ soldout_label }}{% endif %}
            </button>
          </div>

          {%- comment -%} ─ Zweiten Teppich hinzufügen: legt den aktuellen in den Warenkorb,
              leert das Formular und scrollt hoch zum Namensfeld ─ {%- endcomment -%}
          <button type="button" id="gw-reset-btn" class="gw-reset-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            {{ section.settings.reset_label | default: 'Weiteren Teppich personalisieren' }}
          </button>

          {%- comment -%}
            Kein payment_button — Dynamic Checkout (Klarna, Shop Pay usw.) würde die
            Gebetskette und alle Add-ons überspringen, da er nicht durch unsere Cart API läuft.
            Stattdessen: eigener "Jetzt kaufen"-Button → addToCart() → /checkout
          {%- endcomment -%}
          {%- if current_variant.available -%}
            <button type="button" id="gw-buy-now-btn" class="gw-buy-now-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>
              {{ section.settings.buy_now_label | default: 'Jetzt kaufen' }}
            </button>
          {%- endif -%}

          {%- comment -%} Trust badges — from blocks {%- endcomment -%}
          {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
          {%- if trust_blocks.size > 0 -%}
            <div class="gw-trust-badges">
              {%- for block in trust_blocks -%}
                <div class="gw-trust-badge" {{ block.shopify_attributes }}>
                  {%- case block.settings.icon -%}
                    {%- when 'lock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    {%- when 'shield' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    {%- when 'heart' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                    {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {%- when 'truck' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    {%- when 'star' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                    {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {%- endcase -%}
                  <span>{{ block.settings.label }}</span>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        {%- endform -%}

        {%- comment -%} ─ Shipping info — eigene Blöcke im Theme-Editor ─ {%- endcomment -%}
        {%- assign shipping_blocks = section.blocks | where: 'type', 'shipping_row' -%}
        {%- if shipping_blocks.size > 0 -%}
          <div class="gw-product__shipping">
            {%- for block in shipping_blocks -%}
              {%- if block.settings.text != blank -%}
                <div class="gw-product__shipping-row" {{ block.shopify_attributes }}>
                  {%- case block.settings.icon -%}
                    {%- when 'package' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    {%- when 'gift' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                    {%- when 'clock' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    {%- when 'check' -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {%- else -%}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- endcase -%}
                  <span>{{ block.settings.text }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} ─ Accordions: Produktbeschreibung immer oben, dann Blocks ─ {%- endcomment -%}
        {%- assign accordion_blocks = section.blocks | where: 'type', 'accordion' -%}
        {%- if product.description != blank or accordion_blocks.size > 0 -%}
          <div class="gw-product-accordion">
            {%- if product.description != blank -%}
              <details>
                <summary>{{ section.settings.desc_accordion_title | default: 'Beschreibung & Material' }}</summary>
                <div class="gw-product-accordion__body">{{ product.description }}</div>
              </details>
            {%- endif -%}
            {%- for block in accordion_blocks -%}
              <details {{ block.shopify_attributes }}>
                <summary>{{ block.settings.title }}</summary>
                <div class="gw-product-accordion__body">{{ block.settings.content }}</div>
              </details>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </aside>
    </div>
  </div>
</div>

{%- comment -%} Sticky mobile CTA {%- endcomment -%}
<div id="gw-sticky-atc" class="gw-sticky-atc" hidden>
  <div class="gw-sticky-atc__inner">
    <div>
      <p class="gw-sticky-atc__title">{{ product.title | truncate: 30 }}</p>
      <p id="gw-sticky-price" class="gw-sticky-atc__price">{{ current_variant.price | money }}</p>
    </div>
    <button type="button" id="gw-sticky-atc-btn" class="gw-add-to-cart gw-sticky-atc__button">
      {{ atc_label }}
    </button>
  </div>
</div>

<script src="{{ 'gebetswerk-product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Produktseite",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "📝 Beschriftungen & Buttons"
    },
    { "type": "text", "id": "subtitle", "label": "Untertitel (unter dem Produkttitel)", "default": "Mit dem Namen deiner Wahl bestickt – ein Geschenk, das bleibt.", "info": "Kurzer emotionaler Satz. Erscheint direkt unter dem Titel und stärkt SEO & Conversion." },
    { "type": "text", "id": "label_color", "label": "Label: Farbauswahl", "default": "Farbe" },
    { "type": "text", "id": "label_name1", "label": "Label: 1. Name", "default": "Name 1" },
    { "type": "text", "id": "placeholder_name1", "label": "Platzhalter: 1. Name", "default": "z. B. Amina" },
    { "type": "text", "id": "toggle_two_names", "label": "Text: Zweiter-Name-Schalter", "default": "Zweiten Namen hinzufügen" },
    { "type": "text", "id": "label_name2", "label": "Label: 2. Name", "default": "Name 2" },
    { "type": "text", "id": "placeholder_name2", "label": "Platzhalter: 2. Name", "default": "z. B. Yusuf" },
    { "type": "number", "id": "name_max", "label": "Max. Zeichen pro Name", "default": 11 },
    { "type": "text", "id": "label_thread", "label": "Label: Schriftfarbe", "default": "Schriftfarbe" },
    { "type": "text", "id": "label_symbol", "label": "Label: Symbol", "default": "Symbol" },
    { "type": "text", "id": "label_sympos", "label": "Label: Symbolposition", "default": "Position des Symbols" },
    { "type": "text", "id": "summary_label", "label": "Label: Bestellübersicht", "default": "Deine Bestellung:" },
    { "type": "text", "id": "atc_label", "label": "Button: In den Warenkorb", "default": "In den Warenkorb" },
    { "type": "text", "id": "added_label", "label": "Button: Erfolgs-Text", "default": "✓ Im Warenkorb" },
    { "type": "text", "id": "buy_now_label", "label": "Button: Jetzt kaufen", "default": "Jetzt kaufen" },
    { "type": "text", "id": "reset_label", "label": "Button: Weiterer Teppich", "default": "Weiteren Teppich personalisieren" },
    { "type": "text", "id": "soldout_label", "label": "Text: Ausverkauft", "default": "Ausverkauft" },
    { "type": "text", "id": "urgency_text", "label": "Text: Niedriger Lagerbestand", "default": "Nur noch [Anzahl] Stück verfügbar", "info": "[Anzahl] wird automatisch durch den Lagerbestand ersetzt" },
    { "type": "text", "id": "desc_accordion_title", "label": "Titel: Beschreibungs-Klappbox", "default": "Produktbeschreibung" },
    {
      "type": "header",
      "content": "✏️ Personalisierungsbox"
    },
    {
      "type": "text",
      "id": "personalize_title",
      "label": "Checkbox-Titel",
      "default": "Gebetsteppich personalisieren?",
      "info": "Große Schrift in der Personalisierungs-Checkbox"
    },
    {
      "type": "text",
      "id": "personalize_desc",
      "label": "Beschreibungstext",
      "default": "Mit gestickten Namen wird dein Geschenk einzigartig.",
      "info": "Der Aufpreis (+€10,00) wird automatisch aus den Preisen unten berechnet"
    },
    {
      "type": "header",
      "content": "⭐ Badge & Bewertung"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge-Text (über dem Produkttitel)",
      "default": "Personalisiertes Set",
      "info": "Kleines goldenes Label, z. B. 'Bestseller' oder 'Neu'"
    },
    {
      "type": "header",
      "content": "📊 Lagerbestand-Warnung"
    },
    {
      "type": "number",
      "id": "inventory_threshold",
      "label": "Warnung anzeigen ab (Stück)",
      "default": 10,
      "info": "Zeigt 'Nur noch X Stück verfügbar' wenn der Bestand darunter fällt"
    },
    {
      "type": "header",
      "content": "🚚 Dynamische Lieferzeit"
    },
    {
      "type": "checkbox",
      "id": "delivery_show",
      "label": "Lieferzeit-Box anzeigen",
      "default": true,
      "info": "Zeigt ein voraussichtliches Lieferdatum. Schaltet automatisch auf Express um, sobald die Kundin die Expressanfertigung wählt."
    },
    {
      "type": "text",
      "id": "delivery_label",
      "label": "Überschrift über dem Datum",
      "default": "Voraussichtliche Lieferung",
      "info": "Das berechnete Lieferdatum erscheint automatisch darunter."
    },
    {
      "type": "textarea",
      "id": "delivery_standard_text",
      "label": "Erklärzeile: Standard-Anfertigung",
      "default": "Standard-Anfertigung: 2–4 Werktage + Versand (AT 1–2, DE 2–4 Tage)."
    },
    {
      "type": "textarea",
      "id": "delivery_express_text",
      "label": "Erklärzeile: Express-Anfertigung",
      "default": "Wir starten sofort mit deiner Bestellung – bevorzugt vor allen anderen."
    },
    {
      "type": "textarea",
      "id": "delivery_express_hint",
      "label": "Kleingedruckter Hinweis (Express)",
      "default": "Das genaue Zustelldatum hängt zusätzlich vom Versanddienstleister ab."
    },
    {
      "type": "paragraph",
      "content": "Lieferdatum = Bearbeitungstage + Versandtage (nur Werktage Mo–Fr). Standard-Lieferung wird als Spanne vom frühesten bis spätesten Werktag angezeigt."
    },
    { "type": "number", "id": "delivery_prod_min", "label": "Bearbeitung Standard: min. Werktage", "default": 2 },
    { "type": "number", "id": "delivery_prod_max", "label": "Bearbeitung Standard: max. Werktage", "default": 4 },
    { "type": "number", "id": "delivery_ship_min", "label": "Versand: min. Werktage", "default": 1 },
    { "type": "number", "id": "delivery_ship_max", "label": "Versand: max. Werktage", "default": 4 },
    { "type": "number", "id": "delivery_exp_min", "label": "Express gesamt: min. Werktage", "default": 1 },
    { "type": "number", "id": "delivery_exp_max", "label": "Express gesamt: max. Werktage", "default": 3 },
    { "type": "number", "id": "delivery_cutoff_hour", "label": "Redaktionsschluss (Stunde 0–23)", "default": 14, "info": "Bestellungen nach dieser Uhrzeit starten am nächsten Tag." },
    {
      "type": "header",
      "content": "💰 Aufpreise für Personalisierung"
    },
    {
      "type": "product",
      "id": "addon_product",
      "label": "Aufpreise-Produkt",
      "info": "Das versteckte 'Aufpreise'-Produkt auswählen. Dann gelten automatisch dessen echte Variantenpreise und die Cent-Felder unten werden ignoriert."
    },
    {
      "type": "paragraph",
      "content": "Fallback-Preise in Cent (nur wenn kein Aufpreise-Produkt verknüpft ist): 1000 = €10,00 · 199 = €1,99"
    },
    {
      "type": "number",
      "id": "price_name1",
      "label": "Aufpreis: 1. Name",
      "default": 1000
    },
    {
      "type": "number",
      "id": "price_name2",
      "label": "Aufpreis: 2. Name (zusätzlich)",
      "default": 1500
    },
    {
      "type": "number",
      "id": "price_symbol",
      "label": "Aufpreis: Symbol",
      "default": 400
    },
    {
      "type": "header",
      "content": "🔧 Technisch: Aufpreis-Variant IDs"
    },
    {
      "type": "paragraph",
      "content": "Für korrekten Warenkorb-Gesamtpreis: Im Shopify Admin ein verstecktes Produkt 'Aufpreise' erstellen. Die Variant ID jeder Option hier eintragen."
    },
    {
      "type": "number",
      "id": "addon_name1_variant_id",
      "label": "Variant ID → 1. Name (€10)",
      "info": "Shopify Admin → Produkte → Aufpreise → Variante kopieren"
    },
    {
      "type": "number",
      "id": "addon_name2_variant_id",
      "label": "Variant ID → 2. Name (€15)"
    },
    {
      "type": "number",
      "id": "addon_symbol_variant_id",
      "label": "Variant ID → Symbol (€4,00)"
    }
  ],
  "blocks": [
    {
      "type": "shipping_row",
      "name": "📦 Versand-Hinweis",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck",   "label": "🚚 LKW (Versand)" },
            { "value": "package", "label": "📦 Paket (Lieferung)" },
            { "value": "gift",    "label": "🎁 Geschenk (Verpackung)" },
            { "value": "clock",   "label": "🕐 Uhr (Lieferzeit)" },
            { "value": "check",   "label": "✓ Haken" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Österreich kostenlos · Deutschland kostenlos ab 100 €"
        }
      ]
    },
    {
      "type": "thread_color",
      "name": "🎨 Schriftfarbe",
      "limit": 8,
      "settings": [
        {
          "type": "text",
          "id": "id",
          "label": "ID (intern, keine Leerzeichen)",
          "default": "gold",
          "info": "Wird intern gespeichert, z. B. 'gold', 'silber', 'weiss'"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Anzeigename",
          "default": "Gold"
        },
        {
          "type": "color",
          "id": "hex",
          "label": "Farbe als Hex-Code",
          "default": "#c9a24a"
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "✅ Vertrauens-Badge",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "lock",   "label": "🔒 Schloss (Sicherheit)" },
            { "value": "shield", "label": "🛡️ Schild (Garantie)" },
            { "value": "heart",  "label": "❤️ Herz (Handarbeit)" },
            { "value": "clock",  "label": "🕐 Uhr (Lieferzeit)" },
            { "value": "truck",  "label": "🚚 LKW (Versand)" },
            { "value": "star",   "label": "⭐ Stern (Bewertung)" },
            { "value": "gift",   "label": "🎁 Geschenk (Verpackung)" },
            { "value": "check",  "label": "✓ Haken (Bestätigung)" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "SSL-gesichert"
        }
      ]
    },
    {
      "type": "opt_text",
      "name": "📝 Textfeld",
      "settings": [
        { "type": "text",     "id": "label",         "label": "Bezeichnung",                    "default": "Zusatz-Name" },
        { "type": "text",     "id": "field_key",      "label": "Schlüssel (erscheint in Bestellung)", "default": "Zusatz-Name", "info": "z.B. 'Gravur', 'Name 3', 'Wunschtext'" },
        { "type": "text",     "id": "placeholder",    "label": "Platzhaltertext",                "default": "z.B. Amina" },
        { "type": "number",   "id": "max_chars",      "label": "Max. Zeichen (0 = unbegrenzt)",  "default": 20 },
        { "type": "checkbox", "id": "show_char_counter", "label": "Zeichenzähler anzeigen",      "default": true },
        { "type": "checkbox", "id": "required",       "label": "Pflichtfeld",                    "default": false },
        { "type": "number",   "id": "surcharge_cents","label": "Aufpreis in Cent (0 = kostenlos)","default": 0, "info": "Wird nur berechnet wenn das Feld ausgefüllt ist. 1000 = €10,00" },
        { "type": "number",   "id": "addon_variant_id","label": "Aufpreis-Variant ID",            "default": 0, "info": "Optional: Shopify-Variant-ID für separaten Warenkorb-Artikel" }
      ]
    },
    {
      "type": "opt_checkbox",
      "name": "☑️ Checkbox-Option",
      "settings": [
        { "type": "text",     "id": "label",         "label": "Beschriftung",                   "default": "Geschenkverpackung" },
        { "type": "text",     "id": "icon",          "label": "Icon / Emoji (optional)",         "info": "Erscheint vor dem Text, z.B. 🎁" },
        { "type": "text",     "id": "description",   "label": "Erklärungstext (optional)" },
        { "type": "textarea", "id": "tooltip",       "label": "Info-Text hinter Fragezeichen (optional)", "info": "Zeigt ein ?-Symbol neben der Beschriftung. Beim Antippen erscheint dieser Text — z. B. was Expressanfertigung bedeutet." },
        { "type": "text",     "id": "field_key",     "label": "Schlüssel (Bestellung)",          "default": "Geschenkverpackung" },
