<section class="gw-reviews-section" id="gw-reviews">
  <div class="gw-reviews-section__inner">

    <div class="gw-reviews-section__header">
      <p class="gw-reviews-section__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="gw-reviews-section__title">{{ section.settings.heading }}</h2>
    </div>

    {%- comment -%}
      Judge.me rendert die Reviews server-seitig über seinen App Block
      (Theme App Extension). Im Theme-Editor: Section → "Block hinzufügen"
      → Judge.me "Review Widget". Legacy-Divs (jdgm-widget + data-id)
      werden von der neuen App-Embed-Version NICHT mehr befüllt.
    {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {% render block %}
      {%- endfor -%}
    {%- else -%}
      <div class="gw-reviews-fallback">
        <p class="gw-reviews-fallback__text">Füge im Theme-Editor den Judge.me „Review Widget"-Block zu dieser Section hinzu.</p>
        <p class="gw-reviews-fallback__hint">Section auswählen → Block hinzufügen → Apps → Judge.me Review Widget</p>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ── Reviews Section ──────────────────────────────────────────── */
.gw-reviews-section {
  background: var(--gw-ivory, #F9F6F0);
  padding: 72px 20px;
  border-top: 1px solid var(--gw-border, #E5E0D8);
}
@media (min-width: 750px) { .gw-reviews-section { padding: 80px 40px; } }

.gw-reviews-section__inner {
  max-width: 960px;
  margin: 0 auto;
}

.gw-reviews-section__header {
  text-align: center;
  margin-bottom: 48px;
}

.gw-reviews-section__eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gw-gold, #C89B3C);
  margin: 0 0 10px;
}

.gw-reviews-section__title {
  font-family: 'Fraunces', 'Times New Roman', serif;
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--gw-ink, #1A1613);
  margin: 0;
}

/* ── Judge.me — vollständiges Gebetswerk Branding ─────────────── */

/* Sterne: Gold statt Blau — global auf ganzer Seite */
.jdgm-star { color: var(--gw-gold, #C89B3C) !important; }
.jdgm-star.jdgm--empty { color: #D9D3C7 !important; }

/* Preview-Badge auf Produktseite & Collection-Karten */
.jdgm-prev-badge {
  font-family: 'Inter', system-ui, sans-serif !important;
  font-size: 12px !important;
  color: var(--gw-muted, #6B6560) !important;
}
.jdgm-prev-badge__text { color: var(--gw-muted, #6B6560) !important; }

/* ── Judge.me Review Widget (neue jm-* Klassen, App-Block-Version) ── */
.gw-reviews-section .jdgm-widget,
.gw-reviews-section .jm-review-widget {
  font-family: 'Inter', system-ui, sans-serif !important;
  color: var(--gw-ink, #1A1613) !important;
  background: transparent !important;
}

/* Widget-eigenen Titel ausblenden — unser Section-Heading reicht */
.gw-reviews-section .jm-review-widget-minimal-header__title { display: none !important; }

/* Sterne: Gold */
.gw-reviews-section .jm-star-rating,
.gw-reviews-section .jm-star-rating__font-icon {
  color: var(--gw-gold, #C89B3C) !important;
  fill: var(--gw-gold, #C89B3C) !important;
}
.gw-reviews-section .jm-star-rating svg,
.gw-reviews-section .jm-star-rating svg * {
  fill: var(--gw-gold, #C89B3C) !important;
}

/* Durchschnitts-Rating groß in Fraunces */
.gw-reviews-section .jm-average-rating-display {
  font-family: 'Fraunces', serif !important;
  color: var(--gw-ink, #1A1613) !important;
}

/* Einzelne Review-Karte */
.gw-reviews-section .jm-review-item {
  background: #fff !important;
  border: 1px solid var(--gw-border, #E5E0D8) !important;
  border-radius: 16px !important;
  padding: 24px !important;
  margin-bottom: 16px !important;
  box-shadow: none !important;
}

/* Texte: Ink statt Schwarz */
.gw-reviews-section .jm-review-widget .jm-text,
.gw-reviews-section .jm-review-item {
  color: var(--gw-ink, #1A1613) !important;
}

/* Buttons (Bewertung schreiben, Mehr laden) */
.gw-reviews-section .jm-button--primary {
  font-family: 'Inter', system-ui, sans-serif !important;
  background: var(--gw-gold, #C89B3C) !important;
  color: #fff !important;
  border: none !important;
  border-radius: 100px !important;
  font-weight: 600 !important;
  letter-spacing: 0.03em !important;
  transition: background 0.2s !important;
}
.gw-reviews-section .jm-button--primary:hover {
  background: #b8871f !important;
}
.gw-reviews-section .jm-button--secondary,
.gw-reviews-section .jm-button--tertiary {
  font-family: 'Inter', system-ui, sans-serif !important;
  color: var(--gw-ink, #1A1613) !important;
  border-color: var(--gw-border, #E5E0D8) !important;
  border-radius: 100px !important;
}

/* Pagination: nur die AKTIVE Seite gold — Judge.me gibt allen
   Seitenzahlen jm-button--primary, unterscheidbar nur via aria-current */
.gw-reviews-section .jm-pagination-controls .jm-button--primary {
  background: transparent !important;
  color: var(--gw-ink, #1A1613) !important;
  border: 1px solid var(--gw-border, #E5E0D8) !important;
}
.gw-reviews-section .jm-pagination-controls .jm-button[aria-current="page"] {
  background: var(--gw-gold, #C89B3C) !important;
  color: #fff !important;
  border-color: var(--gw-gold, #C89B3C) !important;
}
.gw-reviews-section .jm-pagination-controls .jm-button--primary:hover:not([aria-current="page"]) {
  background: var(--gw-sand, #EDE8DF) !important;
}

/* Header-Zeile (Bewertung schreiben / Filter / Sortierung) vereinheitlichen */
.gw-reviews-section .jm-review-widget-minimal-header__button-and-filters .jm-button,
.gw-reviews-section .jm-sort-filter__select {
  min-height: 36px !important;
  border-radius: 100px !important;
}
.gw-reviews-section select.jm-sort-filter__select,
.gw-reviews-section select.jdgm-sort-dropdown.jm-sort-filter__select,
.gw-reviews-section .jm-sort-filter__select {
  border-radius: 100px !important;
  font-family: 'Inter', system-ui, sans-serif !important;
  border-color: var(--gw-border, #E5E0D8) !important;
  color: var(--gw-ink, #1A1613) !important;
  padding-left: 14px !important;
  padding-right: 28px !important;
}

/* Formular-Inputs */
.gw-reviews-section .jm-review-widget input,
.gw-reviews-section .jm-review-widget textarea,
.gw-reviews-section .jm-review-widget select {
  font-family: 'Inter', system-ui, sans-serif !important;
  border: 1px solid var(--gw-border, #E5E0D8) !important;
  border-radius: 8px !important;
  background: #fff !important;
  color: var(--gw-ink, #1A1613) !important;
}
.gw-reviews-section .jm-review-widget input:focus,
.gw-reviews-section .jm-review-widget textarea:focus {
  border-color: var(--gw-gold, #C89B3C) !important;
  outline: none !important;
}

/* ── Judge.me Featured Carousel (Startseite) ──────────────────── */
/* Carousel-eigener Titel + Rating-Zeile ausblenden — Section-Header reicht */
.gw-reviews-section .jdgm-carousel-title-and-link { display: none !important; }

/* Riesige Lücke zum Header schließen (Wrapper-Padding + Carousel-Margin) */
.gw-reviews-section .jdgm-carousel-wrapper { padding-top: 0 !important; }
.gw-reviews-section .jdgm-carousel.jdgm-widget { margin-top: 0 !important; }

/* Gequetschtes Mini-Produktbild unter den Reviews ausblenden */
.gw-reviews-section .jdgm-carousel-item__product { display: none !important; }

.gw-reviews-section .jdgm-carousel-item {
  background: #fff !important;
  border: 1px solid var(--gw-border, #E5E0D8) !important;
  border-radius: 16px !important;
  box-shadow: none !important;
}
.gw-reviews-section .jdgm-carousel-item__review-body,
.gw-reviews-section .jdgm-carousel-item__review-title {
  font-family: 'Inter', system-ui, sans-serif !important;
  color: var(--gw-ink, #1A1613) !important;
}
.gw-reviews-section .jdgm-carousel-item__reviewer-name {
  font-family: 'Inter', system-ui, sans-serif !important;
  font-weight: 600 !important;
  color: var(--gw-ink, #1A1613) !important;
}
.gw-reviews-section .jdgm-carousel__arrows .jdgm-carousel-arrow,
.gw-reviews-section [class*="jdgm-carousel"] .jdgm-star {
  color: var(--gw-gold, #C89B3C) !important;
}

/* Fallback — shown until Judge.me widget has content */
.gw-reviews-fallback {
  text-align: center;
  padding: 32px;
  border: 1px dashed var(--gw-border, #E5E0D8);
  border-radius: 12px;
}
.gw-reviews-fallback__text {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 15px;
  color: var(--gw-ink, #1A1613);
  margin: 0 0 8px;
}
.gw-reviews-fallback__hint {
  font-size: 12px;
  color: var(--gw-muted, #6B6560);
  margin: 0;
}

/* Hide fallback once Judge.me widget has rendered content */
.jdgm-review-widget:not(:empty) ~ #gw-reviews-fallback,
.jdgm-review-widget[data-loaded] ~ #gw-reviews-fallback { display: none; }
</style>

{% schema %}
{
  "name": "Reviews (Judge.me)",
  "tag": "section",
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kundenbewertungen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Was unsere Kunden sagen"
    }
  ],
  "presets": [
    {
      "name": "Reviews (Judge.me)"
    }
  ]
}
{% endschema %}
