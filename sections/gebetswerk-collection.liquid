{%- liquid
  if section.settings.collection != blank
    assign col = collections[section.settings.collection]
  else
    assign col = collection
  endif
  assign prefix = section.settings.name_prefix | default: 'Personalisierter Gebetsteppich'
  assign suffix = section.settings.name_suffix | default: '· Geschenk'
-%}

<div class="gw-col-page">

  {%- comment -%} ── Hero Banner ── {%- endcomment -%}
  <div class="gw-col-banner">
    <div class="gw-col-banner__inner">
      <p class="gw-col-banner__eyebrow">{{ section.settings.eyebrow | default: 'Manufaktur · Made in Europe' }}</p>
      <h1 class="gw-col-banner__title">
        {%- if col.title != blank -%}{{ col.title }}{%- else -%}{{ section.settings.heading | default: 'Unsere Gebetsteppiche' }}{%- endif -%}
      </h1>
      {%- if col.description != blank -%}
        <p class="gw-col-banner__desc">{{ col.description }}</p>
      {%- elsif section.settings.description != blank -%}
        <p class="gw-col-banner__desc">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Grid ── {%- endcomment -%}
  <div class="gw-col-grid-wrap">

    {%- comment -%} Product count bar {%- endcomment -%}
    <div class="gw-col-meta">
      {%- if col != blank -%}
        <span class="gw-col-meta__count">{{ col.products_count }} Produkte</span>
      {%- endif -%}
    </div>

    <div class="gw-col-grid">

      {%- if col != blank -%}
        {%- assign card_count = 0 -%}
        {%- assign limit = section.settings.products_per_page | default: 24 -%}

        {%- for product in col.products -%}
          {%- if card_count >= limit -%}{%- break -%}{%- endif -%}

          {%- assign color_opt = nil -%}
          {%- for opt in product.options_with_values -%}
            {%- assign opt_lower = opt.name | downcase -%}
            {%- if opt_lower == 'farbe' or opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'farben' -%}
              {%- assign color_opt = opt -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if color_opt != nil -%}
            {%- for color_val in color_opt.values -%}
              {%- if card_count >= limit -%}{%- break -%}{%- endif -%}

              {%- assign card_variant = nil -%}
              {%- for v in product.variants -%}
                {%- if v.options contains color_val -%}
                  {%- assign card_variant = v -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if card_variant == nil -%}{%- continue -%}{%- endif -%}

              {%- if card_variant.featured_image -%}
                {%- assign card_img   = card_variant.featured_image -%}
              {%- else -%}
                {%- assign card_img   = product.featured_media -%}
              {%- endif -%}
              {%- assign card_url     = product.url | append: '?variant=' | append: card_variant.id -%}
              {%- assign card_title   = prefix | append: ' – ' | append: color_val | append: ' ' | append: suffix -%}
              {%- assign card_price   = card_variant.price -%}

              <article class="gw-col-card">
                <a href="{{ card_url }}" class="gw-col-card__link" aria-label="{{ card_title | escape }}" title="{{ card_title | escape }}">
                <div class="gw-col-card__img-wrap">
                  {%- if card_img -%}
                    <img src="{{ card_img | image_url: width: 700 }}" alt="{{ card_title | escape }}" width="700" loading="lazy">
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-col-card__placeholder' }}
                  {%- endif -%}
                  {%- unless card_variant.available -%}
                    <span class="gw-col-card__badge gw-col-card__badge--sold">Ausverkauft</span>
                  {%- endunless -%}
                  {%- if card_variant.compare_at_price > card_variant.price -%}
                    <span class="gw-col-card__badge gw-col-card__badge--sale">Sale</span>
                  {%- endif -%}
                </div>
                <div class="gw-col-card__info">
                  <p class="gw-col-card__color">{{ color_val }}</p>
                  <p class="gw-col-card__name">{{ card_title }}</p>
                  <div class="gw-col-card__rating">
                    {% render 'gw-rating-stars', product: product %}
                  </div>
                  <p class="gw-col-card__price">
                    {%- if card_variant.compare_at_price > card_variant.price -%}
                      <span class="gw-col-card__price-orig">{{ card_variant.compare_at_price | money }}</span>
                    {%- endif -%}
                    {{ card_price | money }}
                  </p>
                </div>
                </a>

              </article>

              {%- assign card_count = card_count | plus: 1 -%}
            {%- endfor -%}

          {%- else -%}
            <a href="{{ product.url }}" class="gw-col-card" aria-label="{{ product.title | escape }}">
              <div class="gw-col-card__img-wrap">
                {%- if product.featured_media -%}
                  <img src="{{ product.featured_media | image_url: width: 700 }}" alt="{{ product.featured_media.alt | escape }}" width="700" loading="lazy">
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-col-card__placeholder' }}
                {%- endif -%}
              </div>
              <div class="gw-col-card__info">
                <p class="gw-col-card__name">{{ product.title }}</p>
                <div class="gw-col-card__rating">
                  {% render 'gw-rating-stars', product: product %}
                </div>
                <p class="gw-col-card__price">
                  {%- if product.price_varies -%}ab {% endif %}{{ product.price | money }}
                </p>
              </div>
            </a>
            {%- assign card_count = card_count | plus: 1 -%}
          {%- endif -%}

        {%- endfor -%}

      {%- else -%}
        {%- assign placeholder_colors = 'Weiß,Creme,Sand,Dunkelblau,Bordeaux,Schwarz' | split: ',' -%}
        {%- for color_val in placeholder_colors -%}
          <div class="gw-col-card gw-col-card--placeholder">
            <div class="gw-col-card__img-wrap">{{ 'product-apparel-1' | placeholder_svg_tag: 'gw-col-card__placeholder' }}</div>
            <div class="gw-col-card__info">
              <p class="gw-col-card__color">{{ color_val }}</p>
              <p class="gw-col-card__name">{{ prefix }} – {{ color_val }} {{ suffix }}</p>
              <p class="gw-col-card__price">ab 49,90 €</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>
</div>

<style>
/* ── Collection Page ──────────────────────────────────────────── */
.gw-col-page {
  background: var(--gw-ivory, #F9F6F0);
  min-height: 60vh;
}

/* Banner */
.gw-col-banner {
  background: var(--gw-sand, #EDE8DF);
  padding: 56px 20px 48px;
  text-align: center;
}
@media (min-width: 750px) { .gw-col-banner { padding: 72px 40px 60px; } }

.gw-col-banner__inner {
  max-width: 600px;
  margin: 0 auto;
}

.gw-col-banner__eyebrow {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gw-gold, #C89B3C);
  margin: 0 0 12px;
}

.gw-col-banner__title {
  font-family: 'Fraunces', 'Times New Roman', serif;
  font-size: clamp(32px, 5vw, 52px);
  font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--gw-ink, #1A1613);
  margin: 0 0 14px;
  line-height: 1.1;
}

.gw-col-banner__desc {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 15px;
  color: var(--gw-muted, #6B6560);
  margin: 0;
  line-height: 1.6;
}

/* Grid wrapper */
.gw-col-grid-wrap {
  max-width: 1320px;
  margin: 0 auto;
  padding: 36px 20px 72px;
}
@media (min-width: 750px) { .gw-col-grid-wrap { padding: 44px 40px 80px; } }

.gw-col-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--gw-border, #E5E0D8);
}

.gw-col-meta__count {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 12px;
  font-weight: 500;
  color: var(--gw-muted, #6B6560);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

/* Grid */
.gw-col-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}
@media (min-width: 600px) { .gw-col-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
@media (min-width: 1024px) { .gw-col-grid { grid-template-columns: repeat(4, 1fr); gap: 24px; } }

/* Card */
.gw-col-card {
  display: flex;
  flex-direction: column;
  gap: 10px;
  color: var(--gw-ink, #1A1613);
}

.gw-col-card__link {
  display: flex;
  flex-direction: column;
  gap: 10px;
  text-decoration: none;
  color: inherit;
}

.gw-col-card__img-wrap {
  position: relative;
  border-radius: 16px;
  overflow: hidden;
  background: var(--gw-sand, #EDE8DF);
  aspect-ratio: 3/4;
}

.gw-col-card__img-wrap img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s ease;
}
.gw-col-card__link:hover .gw-col-card__img-wrap img { transform: scale(1.06); }

/* Swatches */
.gw-col-card__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  padding: 0 2px;
}
.gw-col-card__swatch {
  display: block;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid transparent;
  outline: 1px solid var(--gw-border, #E5E0D8);
  transition: outline-color 0.15s, border-color 0.15s;
  flex-shrink: 0;
}
.gw-col-card__swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.gw-col-card__swatch-dot {
  display: block;
  width: 100%;
  height: 100%;
  background: var(--gw-sand, #EDE8DF);
}
.gw-col-card__swatch.is-active { outline-color: var(--gw-ink, #1A1613); border-color: var(--gw-ivory, #F9F6F0); }
.gw-col-card__swatch:hover { outline-color: var(--gw-gold, #C89B3C); }

.gw-col-card__placeholder { width: 100%; height: 100%; }

.gw-col-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 4px 8px;
  border-radius: 20px;
}
.gw-col-card__badge--sold { background: var(--gw-ink, #1A1613); color: var(--gw-ivory, #F9F6F0); }
.gw-col-card__badge--sale { background: var(--gw-gold, #C89B3C); color: #fff; }

.gw-col-card__info {
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 0 2px;
}

.gw-col-card__color {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gw-muted, #6B6560);
  margin: 0;
}

.gw-col-card__name {
  font-family: 'Fraunces', 'Times New Roman', serif;
  font-size: 14px;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--gw-ink, #1A1613);
  margin: 0;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.gw-col-card__rating {
  min-height: 18px;
}

/* Judge.me placeholder — hidden until app fills it */

.gw-col-card__price {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 13px;
  font-weight: 500;
  color: var(--gw-ink, #1A1613);
  margin: 0;
  margin-top: 2px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.gw-col-card__price-orig {
  text-decoration: line-through;
  color: var(--gw-muted, #6B6560);
  font-weight: 400;
}
</style>


{% schema %}
{
  "name": "Kollektion – Grid",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "Wähle eine Kollektion aus. Leer lassen = aktuelle Kollektionsseite wird verwendet."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Manufaktur · Made in Europe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (Fallback)",
      "info": "Wird nur angezeigt wenn die Kollektion keinen Titel hat",
      "default": "Unsere Gebetsteppiche"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Beschreibung (Fallback)",
      "info": "Wird nur angezeigt wenn die Kollektion keine Beschreibung hat"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Produkte pro Seite",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "SEO-Kartentitel"
    },
    {
      "type": "text",
      "id": "name_prefix",
      "label": "Präfix (vor Farbe)",
      "default": "Personalisierter Gebetsteppich",
      "info": "Ergibt: Personalisierter Gebetsteppich – Weiß · Geschenk"
    },
    {
      "type": "text",
      "id": "name_suffix",
      "label": "Suffix (nach Farbe)",
      "default": "· Geschenk für Mama & Baba"
    }
  ],
  "presets": [
    {
      "name": "Kollektion – Grid"
    }
  ]
}
{% endschema %}
