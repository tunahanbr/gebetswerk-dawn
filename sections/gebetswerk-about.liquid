{{ 'gebetswerk-about.css' | asset_url | stylesheet_tag }}
<section class="gw-about">

  {%- comment -%} ── Hero ── {%- endcomment -%}
  <div class="gw-about__hero">
    <div class="gw-about__hero-inner">
      <p class="gw-eyebrow">{{ section.settings.eyebrow | default: 'Unsere Geschichte' }}</p>
      <h1 class="gw-about__heading">{{ section.settings.heading | default: 'Wir glauben, dass jedes Gebet mit Würde beginnt.' }}</h1>
      <p class="gw-about__lead">{{ section.settings.lead | default: 'Gebetswerk ist ein europäisches Manufaktur-Label für personalisierte Gebetsteppiche — gefertigt mit echter Goldstickerei, mit Liebe zum Detail und dem Wunsch, Familien ein bleibendes Geschenk zu schenken.' }}</p>
    </div>
    {%- if section.settings.hero_image != blank -%}
      <div class="gw-about__hero-img">
        <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" alt="{{ section.settings.heading | escape }}" width="1600" height="{{ 1600 | divided_by: section.settings.hero_image.aspect_ratio | round }}" loading="eager">
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ── Stats bar ── {%- endcomment -%}
  <div class="gw-about__stats">
    <div class="gw-about__stats-inner">
      <div class="gw-about__stat">
        <span class="gw-about__stat-num">{{ section.settings.stat1_num | default: '2.400+' }}</span>
        <span class="gw-about__stat-label">{{ section.settings.stat1_label | default: 'zufriedene Familien' }}</span>
      </div>
      <div class="gw-about__stat-divider"></div>
      <div class="gw-about__stat">
        <span class="gw-about__stat-num">{{ section.settings.stat2_num | default: '4,9 / 5' }}</span>
        <span class="gw-about__stat-label">{{ section.settings.stat2_label | default: 'Kundenbewertung' }}</span>
      </div>
      <div class="gw-about__stat-divider"></div>
      <div class="gw-about__stat">
        <span class="gw-about__stat-num">{{ section.settings.stat3_num | default: 'Made in EU' }}</span>
        <span class="gw-about__stat-label">{{ section.settings.stat3_label | default: 'Manufaktur-Qualität' }}</span>
      </div>
      <div class="gw-about__stat-divider"></div>
      <div class="gw-about__stat">
        <span class="gw-about__stat-num">{{ section.settings.stat4_num | default: '3–5 Tage' }}</span>
        <span class="gw-about__stat-label">{{ section.settings.stat4_label | default: 'bis zur Lieferung' }}</span>
      </div>
    </div>
  </div>

  {%- comment -%} ── Story section ── {%- endcomment -%}
  <div class="gw-about__story">
    <div class="gw-about__story-inner">
      <div class="gw-about__story-text">
        <p class="gw-eyebrow">{{ section.settings.story_eyebrow | default: 'Warum Gebetswerk' }}</p>
        <h2 class="gw-about__section-heading">{{ section.settings.story_heading | default: 'Ein Geschenk, das bleibt.' }}</h2>
        <div class="gw-about__story-body">
          {{ section.settings.story_body | default: '<p>Gebetswerk entstand aus einem persönlichen Moment — dem Wunsch, unseren Eltern etwas zu schenken, das wirklich zählt. Nicht irgendein Teppich, sondern ein Teppich mit ihrem Namen, in ihrer Lieblingsfarbe, mit einem Symbol, das ihnen bedeutet.</p><p>Heute fertigen wir jeden Gebetsteppich in unserer Manufaktur in Europa — Stich für Stich, von Hand. Aus hochwertigem Mikrofaser-Velours, bestickt mit echtem Goldfaden. Verpackt in einem edlen Karton mit Goldschleife.</p><p>Jedes Stück ist ein Original.</p>' }}</div>
      </div>
      {%- if section.settings.story_image != blank -%}
        <div class="gw-about__story-img">
          <img src="{{ section.settings.story_image | image_url: width: 900 }}" alt="Gebetswerk Manufaktur" width="900" height="{{ 900 | divided_by: section.settings.story_image.aspect_ratio | round }}" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Values ── {%- endcomment -%}
  <div class="gw-about__values">
    <div class="gw-about__values-inner">
      <p class="gw-eyebrow gw-about__values-eyebrow">{{ section.settings.values_eyebrow | default: 'Unsere Werte' }}</p>
      <h2 class="gw-about__section-heading gw-about__values-heading">{{ section.settings.values_heading | default: 'Was uns antreibt.' }}</h2>
      <div class="gw-about__values-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'value' -%}
            <div class="gw-about__value" {{ block.shopify_attributes }}>
              <div class="gw-about__value-icon">
                {%- render 'gw-icon', name: block.settings.icon -%}
              </div>
              <h3 class="gw-about__value-title">{{ block.settings.title }}</h3>
              <p class="gw-about__value-text">{{ block.settings.text }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ── CTA ── {%- endcomment -%}
  <div class="gw-about__cta">
    <div class="gw-about__cta-inner">
      <h2 class="gw-about__cta-heading">{{ section.settings.cta_heading | default: 'Bereit für dein persönliches Stück?' }}</h2>
      <p class="gw-about__cta-sub">{{ section.settings.cta_sub | default: 'Wähle Farbe, Stoff & Namen — wir starten sofort mit der Produktion.' }}</p>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="gw-btn-primary">
        {{ section.settings.cta_label | default: 'Jetzt personalisieren' }}
        <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 15L15 5M15 5H7M15 5v8"/></svg>
      </a>
    </div>
  </div>

</section>


{% schema %}
{
  "name": "Über uns",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Unsere Geschichte" },
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Wir glauben, dass jedes Gebet mit Würde beginnt." },
    { "type": "textarea", "id": "lead", "label": "Einleitungstext", "default": "Gebetswerk ist ein europäisches Manufaktur-Label für personalisierte Gebetsteppiche — gefertigt mit echter Goldstickerei, mit Liebe zum Detail." },
    { "type": "image_picker", "id": "hero_image", "label": "Hero-Bild" },
    { "type": "header", "content": "Zahlen & Fakten" },
    { "type": "text", "id": "stat1_num", "label": "Zahl 1", "default": "2.400+" },
    { "type": "text", "id": "stat1_label", "label": "Label 1", "default": "zufriedene Familien" },
    { "type": "text", "id": "stat2_num", "label": "Zahl 2", "default": "4,9 / 5" },
    { "type": "text", "id": "stat2_label", "label": "Label 2", "default": "Kundenbewertung" },
    { "type": "text", "id": "stat3_num", "label": "Zahl 3", "default": "Made in EU" },
    { "type": "text", "id": "stat3_label", "label": "Label 3", "default": "Manufaktur-Qualität" },
    { "type": "text", "id": "stat4_num", "label": "Zahl 4", "default": "3–5 Tage" },
    { "type": "text", "id": "stat4_label", "label": "Label 4", "default": "bis zur Lieferung" },
    { "type": "header", "content": "Story" },
    { "type": "text", "id": "story_eyebrow", "label": "Eyebrow", "default": "Warum Gebetswerk" },
    { "type": "text", "id": "story_heading", "label": "Überschrift", "default": "Ein Geschenk, das bleibt." },
    { "type": "richtext", "id": "story_body", "label": "Text" },
    { "type": "image_picker", "id": "story_image", "label": "Story-Bild" },
    { "type": "header", "content": "Werte" },
    { "type": "text", "id": "values_eyebrow", "label": "Eyebrow", "default": "Unsere Werte" },
    { "type": "text", "id": "values_heading", "label": "Überschrift", "default": "Was uns antreibt." },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "cta_heading", "label": "CTA-Überschrift", "default": "Bereit für dein persönliches Stück?" },
    { "type": "textarea", "id": "cta_sub", "label": "CTA-Untertext", "default": "Wähle Farbe, Stoff & Namen — wir starten sofort mit der Produktion." },
    { "type": "text", "id": "cta_label", "label": "Button-Text", "default": "Jetzt personalisieren" },
    { "type": "url", "id": "cta_url", "label": "Button-Link" }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Wert",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "sparkles", "label": "Funken" },
          { "value": "feather",  "label": "Feder" },
          { "value": "shield",   "label": "Schild" },
          { "value": "gift",     "label": "Geschenk" },
          { "value": "heart",    "label": "Herz" },
          { "value": "star",     "label": "Stern" }
        ], "default": "sparkles" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Handarbeit" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Jeder Gebetsteppich wird von Hand gefertigt und individuell bestickt." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Über uns",
      "blocks": [
        { "type": "value", "settings": { "icon": "sparkles", "title": "Echte Goldstickerei", "text": "Feiner Metallfaden, von erfahrenen Stickern Stich für Stich gesetzt." } },
        { "type": "value", "settings": { "icon": "shield",   "title": "Lebenslange Qualität", "text": "Farbecht, formstabil und waschbar bei 30 °C – für Generationen." } },
        { "type": "value", "settings": { "icon": "heart",    "title": "Mit Liebe gemacht",    "text": "Jedes Stück entsteht mit dem Bewusstsein, dass es ein besonderes Geschenk sein wird." } },
        { "type": "value", "settings": { "icon": "gift",     "title": "Geschenkfertig",       "text": "Edler Karton mit Goldschleife – bereit zum Verschenken." } }
      ]
    }
  ]
}
{% endschema %}
