<div class="gw-footer-wrap">
<footer class="gw-footer">
  <div class="gw-footer__inner">
    <div class="gw-footer__grid">

      {%- comment -%} Brand + newsletter {%- endcomment -%}
      <div>
        <a href="{{ routes.root_url }}" class="gw-footer__logo" aria-label="{{ section.settings.brand_name | escape }}">
          {%- if section.settings.logo_image != blank -%}
            {%- assign logo_w = section.settings.logo_width | default: 160 -%}
            <img
              src="{{ section.settings.logo_image | image_url: width: 400 }}"
              alt="{{ section.settings.brand_name | escape }}"
              class="gw-footer__logo-img"
              width="{{ logo_w }}"
              height="{{ logo_w | divided_by: section.settings.logo_image.aspect_ratio | round }}"
              style="width:{{ logo_w }}px"
              loading="lazy"
            >
          {%- else -%}
            <span class="gw-footer__logo-mark">{{ section.settings.logo_initials }}</span>
            <span class="gw-footer__logo-name" style="color: white;">{{ section.settings.brand_name }}</span>          
        {%- endif -%}
        </a>
        <p class="gw-footer__tagline">{{ section.settings.tagline }}</p>

        {%- comment -%} App-Blöcke (z. B. Shopify-Forms Inline-Formular für Willkommensrabatt) {%- endcomment -%}
        {%- assign has_app_block = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == '@app' -%}{%- assign has_app_block = true -%}{%- endif -%}
        {%- endfor -%}
        {%- if has_app_block -%}
          <div class="gw-footer__apps">
            {%- for block in section.blocks -%}
              {%- if block.type == '@app' -%}
                <div class="gw-footer__app-block" {{ block.shopify_attributes }}>{%- render block -%}</div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_newsletter -%}
          {%- assign welcome_code = section.settings.welcome_code | default: 'WILLKOMMEN10' -%}
          {%- form 'customer', class: 'gw-footer__newsletter', id: 'gw-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter, willkommensrabatt">
            {%- if form.posted_successfully? -%}
              <div class="gw-footer__welcome">
                <p class="gw-footer__welcome-title">{{ section.settings.welcome_success | default: 'Danke! Hier ist dein Willkommensrabatt für deine erste Bestellung:' }}</p>
                <button type="button" class="gw-footer__welcome-code" data-code="{{ welcome_code | escape }}" aria-label="Rabattcode kopieren">
                  <span class="gw-footer__welcome-code-value">{{ welcome_code }}</span>
                  <span class="gw-footer__welcome-copy">Kopieren</span>
                </button>
              </div>
            {%- else -%}
              <div class="gw-footer__email-form">
                <input
                  type="email"
                  name="contact[email]"
                  class="gw-footer__email-input"
                  placeholder="{{ section.settings.email_placeholder }}"
                  required
                  autocomplete="email"
                >
                <button type="submit" class="gw-footer__email-btn">{{ section.settings.email_button }}</button>
              </div>
              {%- if form.errors -%}
                <p class="gw-footer__email-note gw-footer__email-error">{{ form.errors | default_errors }}</p>
              {%- else -%}
                <p class="gw-footer__email-note">{{ section.settings.email_note }}</p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}
        {%- endif -%}
      </div>

      {%- comment -%} Nav: 'column' startet eine neue Spalte, alle 'link'-Blöcke bis zur nächsten Spalte gehören dazu {%- endcomment -%}
      <div class="gw-footer__nav-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            <div {{ block.shopify_attributes }}>
              <p class="gw-footer__nav-heading">{{ block.settings.heading }}</p>
              <ul class="gw-footer__nav-list">
                {%- for inner in section.blocks offset: forloop.index -%}
                  {%- if inner.type == 'column' -%}{%- break -%}{%- endif -%}
                  {%- if inner.type == 'link' and inner.settings.label != blank -%}
                    <li {{ inner.shopify_attributes }}><a href="{{ inner.settings.url | default: '#' }}">{{ inner.settings.label }}</a></li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="gw-footer__bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. {{ section.settings.copyright_suffix }}</p>
      <div class="gw-footer__social">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" aria-label="E-Mail">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>
</div>

<script>
(function () {
  var form = document.getElementById('gw-newsletter-form');
  if (!form) return;
  var codeBtn = form.querySelector('.gw-footer__welcome-code');
  if (codeBtn) {
    /* Nach erfolgreicher Anmeldung sichtbar — zum Code scrollen */
    codeBtn.closest('.gw-footer__welcome')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    codeBtn.addEventListener('click', function () {
      var code = codeBtn.dataset.code || '';
      var label = codeBtn.querySelector('.gw-footer__welcome-copy');
      navigator.clipboard?.writeText(code).then(function () {
        if (label) { label.textContent = 'Kopiert ✓'; setTimeout(function () { label.textContent = 'Kopieren'; }, 2000); }
      }).catch(function () {});
    });
  }
})();
</script>

{% schema %}
{
  "name": "Footer – Gebetswerk",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Marke"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo-Bild",
      "info": "Optional. Wird statt der Initialen angezeigt. Empfohlen: PNG/SVG mit transparentem Hintergrund (heller/weißer Logo, da der Footer dunkel ist)."
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 260,
      "step": 10,
      "unit": "px",
      "label": "Logo-Breite",
      "default": 160
    },
    {
      "type": "text",
      "id": "logo_initials",
      "label": "Logo-Initialen (Fallback ohne Bild)",
      "default": "GW"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Markenname",
      "default": "Gebetswerk"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Personalisierte Gebetsteppiche mit dem Namen deiner Wahl – ein Geschenk, das Generationen bleibt."
    },
    {
      "type": "text",
      "id": "copyright_suffix",
      "label": "Copyright-Zusatz",
      "default": "Mit Liebe gefertigt."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Newsletter anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "E-Mail Placeholder",
      "default": "Deine E-Mail"
    },
    {
      "type": "text",
      "id": "email_button",
      "label": "Button-Text",
      "default": "Abonnieren"
    },
    {
      "type": "text",
      "id": "email_note",
      "label": "Hinweis unter dem Formular",
      "default": "10 % Willkommensrabatt für neue Abonnenten."
    },
    {
      "type": "text",
      "id": "welcome_code",
      "label": "Willkommens-Rabattcode",
      "default": "WILLKOMMEN10",
      "info": "Diesen Code zuerst im Shopify-Admin unter Rabatte anlegen (z. B. 10 % auf erste Bestellung). Wird nach der Anmeldung angezeigt."
    },
    {
      "type": "text",
      "id": "welcome_success",
      "label": "Text nach erfolgreicher Anmeldung",
      "default": "Danke! Hier ist dein Willkommensrabatt für deine erste Bestellung:"
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "text",
      "id": "instagram",
      "label": "Instagram-URL"
    },
    {
      "type": "text",
      "id": "facebook",
      "label": "Facebook-URL"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-Mail-Adresse"
    }
  ],
  "blocks": [
    { "type": "@app" },
    {
      "type": "column",
      "name": "📁 Spalte",
      "settings": [
        {
          "type": "paragraph",
          "content": "Startet eine neue Link-Spalte. Alle 'Link'-Blöcke darunter gehören zu dieser Spalte."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Shop"
        }
      ]
    },
    {
      "type": "link",
      "name": "🔗 Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Text", "default": "Neuer Link" },
        { "type": "url",  "id": "url",   "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer – Gebetswerk",
      "blocks": [
        { "type": "column", "settings": { "heading": "Shop" } },
        { "type": "link", "settings": { "label": "Gebetsteppiche", "url": "/collections/all" } },
        { "type": "link", "settings": { "label": "Gebetsketten",   "url": "/collections/all" } },
        { "type": "column", "settings": { "heading": "Service" } },
        { "type": "link", "settings": { "label": "FAQ",     "url": "/pages/faq" } },
        { "type": "link", "settings": { "label": "Kontakt", "url": "/pages/contact" } },
        { "type": "column", "settings": { "heading": "Über" } },
        { "type": "link", "settings": { "label": "Unsere Geschichte", "url": "/pages/about" } }
      ]
    }
  ]
}
{% endschema %}
