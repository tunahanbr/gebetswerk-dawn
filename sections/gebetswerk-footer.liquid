      "id": "copyright_suffix",
      "label": "Copyright-Zusatz",
      "default": "Mit Liebe gefertigt."
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Newsletter anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "E-Mail Placeholder",
      "default": "Deine E-Mail"
    },
    {
      "type": "text",
      "id": "email_button",
      "label": "Button-Text",
      "default": "Abonnieren"
    },
    {
      "type": "text",
      "id": "email_note",
      "label": "Hinweis unter dem Formular",
