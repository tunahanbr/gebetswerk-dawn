    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "text",
      "id": "instagram",
      "label": "Instagram-URL"
    },
    {
      "type": "text",
      "id": "facebook",
      "label": "Facebook-URL"
    },
    {
      "type": "text",
      "id": "email",
      "label": "E-Mail-Adresse"
    }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Nav-Spalte",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Shop"
        },
        { "type": "text", "id": "link_1_label", "label": "Link 1 – Text" },
        { "type": "url",  "id": "link_1_url",   "label": "Link 1 – URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 – Text" },
        { "type": "url",  "id": "link_2_url",   "label": "Link 2 – URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 – Text" },
        { "type": "url",  "id": "link_3_url",   "label": "Link 3 – URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 – Text" },
        { "type": "url",  "id": "link_4_url",   "label": "Link 4 – URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 – Text" },
        { "type": "url",  "id": "link_5_url",   "label": "Link 5 – URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer – Gebetswerk",
      "blocks": [
        {
          "type": "nav_column",
          "settings": {
            "heading": "Shop",
            "link_1_label": "Gebetsteppiche", "link_1_url": "/collections/all",
            "link_2_label": "Sets",           "link_2_url": "/collections/all",
            "link_3_label": "Gebetsketten",   "link_3_url": "/collections/all",
            "link_4_label": "Geschenkkarten", "link_4_url": "/collections/all"
          }
        },
        {
          "type": "nav_column",
          "settings": {
            "heading": "Service",
            "link_1_label": "Versand & Lieferung", "link_1_url": "/pages/versand",
            "link_2_label": "Rückgabe",            "link_2_url": "/pages/rueckgabe",
            "link_3_label": "FAQ",                 "link_3_url": "/pages/faq",
            "link_4_label": "Kontakt",             "link_4_url": "/pages/contact"
