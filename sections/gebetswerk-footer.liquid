<div class="gw-footer-wrap">
<footer class="gw-footer">
  <div class="gw-footer__inner">
    <div class="gw-footer__grid">

      {%- comment -%} Brand + newsletter {%- endcomment -%}
      <div>
        <a href="{{ routes.root_url }}" class="gw-footer__logo">
          <span class="gw-footer__logo-mark">{{ section.settings.logo_initials }}</span>
          <span class="gw-footer__logo-name">{{ section.settings.brand_name }}</span>
        </a>
        <p class="gw-footer__tagline">{{ section.settings.tagline }}</p>

        {%- if section.settings.show_newsletter -%}
          {%- assign welcome_code = section.settings.welcome_code | default: 'WILLKOMMEN10' -%}
          {%- form 'customer', class: 'gw-footer__newsletter', id: 'gw-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter, willkommensrabatt">
            {%- if form.posted_successfully? -%}
              <div class="gw-footer__welcome">
                <p class="gw-footer__welcome-title">{{ section.settings.welcome_success | default: 'Danke! Hier ist dein Willkommensrabatt für deine erste Bestellung:' }}</p>
                <button type="button" class="gw-footer__welcome-code" data-code="{{ welcome_code | escape }}" aria-label="Rabattcode kopieren">
                  <span class="gw-footer__welcome-code-value">{{ welcome_code }}</span>
                  <span class="gw-footer__welcome-copy">Kopieren</span>
                </button>
              </div>
            {%- else -%}
              <div class="gw-footer__email-form">
                <input
                  type="email"
                  name="contact[email]"
                  class="gw-footer__email-input"
                  placeholder="{{ section.settings.email_placeholder }}"
                  required
                  autocomplete="email"
                >
                <button type="submit" class="gw-footer__email-btn">{{ section.settings.email_button }}</button>
              </div>
              {%- if form.errors -%}
                <p class="gw-footer__email-note gw-footer__email-error">{{ form.errors | default_errors }}</p>
              {%- else -%}
                <p class="gw-footer__email-note">{{ section.settings.email_note }}</p>
              {%- endif -%}
            {%- endif -%}
          {%- endform -%}
        {%- endif -%}
      </div>

      {%- comment -%} Nav columns {%- endcomment -%}
      <div class="gw-footer__nav-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_column' -%}
            <div {{ block.shopify_attributes }}>
              <p class="gw-footer__nav-heading">{{ block.settings.heading }}</p>
              <ul class="gw-footer__nav-list">
                {%- for i in (1..5) -%}
                  {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                  {%- assign url_key   = 'link_' | append: i | append: '_url' -%}
                  {%- assign label = block.settings[label_key] -%}
                  {%- assign url   = block.settings[url_key] -%}
                  {%- if label != blank -%}
                    <li><a href="{{ url | default: '#' }}">{{ label }}</a></li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Bottom bar {%- endcomment -%}
    <div class="gw-footer__bottom">
      <p>© {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. {{ section.settings.copyright_suffix }}</p>
      <div class="gw-footer__social">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" aria-label="E-Mail">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</footer>
</div>

<script>
(function () {
  var form = document.getElementById('gw-newsletter-form');
  if (!form) return;
  var codeBtn = form.querySelector('.gw-footer__welcome-code');
  if (codeBtn) {
    /* Nach erfolgreicher Anmeldung sichtbar — zum Code scrollen */
    codeBtn.closest('.gw-footer__welcome')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    codeBtn.addEventListener('click', function () {
      var code = codeBtn.dataset.code || '';
      var label = codeBtn.querySelector('.gw-footer__welcome-copy');
      navigator.clipboard?.writeText(code).then(function () {
        if (label) { label.textContent = 'Kopiert ✓'; setTimeout(function () { label.textContent = 'Kopieren'; }, 2000); }
      }).catch(function () {});
    });
  }
})();
</script>

{% schema %}
{
