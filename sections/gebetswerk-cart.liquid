  margin: 0 0 20px;
}
.gw-cart-summary__rows { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; }
.gw-cart-summary__row {
  display: flex; justify-content: space-between;
  font-family: 'Inter', system-ui, sans-serif;
