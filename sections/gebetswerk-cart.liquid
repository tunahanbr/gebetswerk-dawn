  margin: 0 auto;
  padding: 0 20px;
}
@media (min-width: 750px) { .gw-cart-page__inner { padding: 0 40px; } }

/* Header */
.gw-cart-header {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--gw-border, #E5E0D8);
}
.gw-cart-header__title {
  font-family: 'Fraunces', serif;
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 400; letter-spacing: -0.02em;
  color: var(--gw-ink, #1A1613);
  margin: 0;
}
.gw-cart-header__count {
  font-family: 'Inter', system-ui, sans-serif;
