  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
}
.gw-cart-item__vendor {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
