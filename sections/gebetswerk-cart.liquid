{%- if cart.item_count == 0 -%}

  {%- comment -%} ── Leerer Warenkorb ── {%- endcomment -%}
  <div class="gw-cart-empty">
    <div class="gw-cart-empty__inner">
      <div class="gw-cart-empty__icon">
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="22" cy="54" r="4"/><circle cx="46" cy="54" r="4"/><path d="M2 4h8l8 32h28l6-22H16"/></svg>
      </div>
      <h1 class="gw-cart-empty__title">Dein Warenkorb ist leer</h1>
      <p class="gw-cart-empty__text">Entdecke unsere personalisierten Gebetsteppiche – ein Geschenk, das bleibt.</p>
      <a href="/collections/all" class="gw-cart-empty__btn">Zur Kollektion</a>
    </div>
  </div>

{%- else -%}

<div class="gw-cart-page" id="gw-cart-page">
  <div class="gw-cart-page__inner">

    {%- comment -%} ── Header ── {%- endcomment -%}
    <div class="gw-cart-header">
      <h1 class="gw-cart-header__title">Dein Warenkorb</h1>
    </div>

    <div class="gw-cart-layout">

      {%- comment -%} ══ ITEMS ══ {%- endcomment -%}
      <div class="gw-cart-items" id="gw-cart-items">
        <form action="/cart" method="post" id="gw-cart-form">

          {%- for item in cart.items -%}

            {%- comment -%} Skip add-on items — they are rendered under their parent below {%- endcomment -%}
            {%- assign is_addon = false -%}
            {%- for p in item.properties -%}
              {%- if p.first == '_TeppichVariant' -%}
                {%- assign is_addon = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if is_addon -%}{%- continue -%}{%- endif -%}

            {%- comment -%} ── Haupt-Produkt ── {%- endcomment -%}
            <div class="gw-cart-item" data-key="{{ item.key }}">

              <a href="{{ item.url }}" class="gw-cart-item__img-link">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title | escape }}" width="150" loading="lazy" class="gw-cart-item__img">
                {%- else -%}
                  <div class="gw-cart-item__img-placeholder">{{ 'product-apparel-1' | placeholder_svg_tag }}</div>
                {%- endif -%}
              </a>

              <div class="gw-cart-item__info">
                <div class="gw-cart-item__top">
                  <div>
                    <p class="gw-cart-item__vendor">{{ item.vendor }}</p>
                    <a href="{{ item.url }}" class="gw-cart-item__name">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p class="gw-cart-item__variant">{{ item.variant.title }}</p>
                    {%- endunless -%}
                  </div>
                  {%- assign group_price = item.final_line_price -%}
                  {%- assign item_ref = '' -%}
                  {%- for p in item.properties -%}
                    {%- if p.first == '_ref' -%}{%- assign item_ref = p.last -%}{%- endif -%}
                  {%- endfor -%}
                  {%- if item_ref != '' -%}
                    {%- for addon in cart.items -%}
                      {%- assign addon_ref = '' -%}
                      {%- assign addon_is_addon = false -%}
                      {%- for ap in addon.properties -%}
                        {%- if ap.first == '_ref' -%}{%- assign addon_ref = ap.last -%}{%- endif -%}
                        {%- if ap.first == '_TeppichVariant' -%}{%- assign addon_is_addon = true -%}{%- endif -%}
                      {%- endfor -%}
                      {%- if addon_is_addon and addon_ref == item_ref -%}
                        {%- assign group_price = group_price | plus: addon.final_line_price -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  <p class="gw-cart-item__price">{{ group_price | money }}</p>
                </div>

                {%- comment -%} Bestellübersicht wie auf der Produktseite {%- endcomment -%}
                {%- assign has_summary = false -%}
                {%- for p in item.properties -%}
                  {%- unless p.first == blank or p.first contains '_' or p.last == blank -%}
                    {%- assign has_summary = true -%}
                  {%- endunless -%}
                {%- endfor -%}
                {%- if has_summary -%}
                  <ul class="gw-cart-item__order-summary">
                    {%- for p in item.properties -%}
                      {%- unless p.first == blank or p.first contains '_' or p.last == blank -%}
                        <li>
                          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
                          <span>{{ p.first }}: <strong>{{ p.last }}</strong></span>
                        </li>
                      {%- endunless -%}
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

                <div class="gw-cart-item__actions">
                  <div class="gw-cart-qty" data-key="{{ item.key }}">
                    <button type="button" class="gw-cart-qty__btn" data-action="minus" aria-label="Weniger">
                      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="10" x2="16" y2="10"/></svg>
                    </button>
                    <span class="gw-cart-qty__val">{{ item.quantity }}</span>
                    <button type="button" class="gw-cart-qty__btn" data-action="plus" aria-label="Mehr">
                      <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><line x1="10" y1="4" x2="10" y2="16"/><line x1="4" y1="10" x2="16" y2="10"/></svg>
                    </button>
                  </div>
                  <button type="button" class="gw-cart-item__remove" data-key="{{ item.key }}" aria-label="Entfernen">
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 6h14M8 6V4h4v2M16 6l-1 11H5L4 6"/></svg>
                    Entfernen
                  </button>
                </div>

              </div>
            </div>

          {%- endfor -%}

        </form>
      </div>

      {%- comment -%} ══ SUMMARY ══ {%- endcomment -%}
      <aside class="gw-cart-summary">
        <div class="gw-cart-summary__box">

          <h2 class="gw-cart-summary__title">Bestellübersicht</h2>

          <div class="gw-cart-summary__rows">
            <div class="gw-cart-summary__row">
              <span>Zwischensumme</span>
              <span id="gw-cart-subtotal">{{ cart.total_price | money }}</span>
            </div>
            <div class="gw-cart-summary__row gw-cart-summary__row--shipping">
              <span>Versand</span>
              <span>
                {%- if cart.total_price >= 10000 -%}
                  <span class="gw-cart-summary__free">Kostenlos 🎉</span>
                {%- else -%}
                  Wird im Checkout berechnet
                {%- endif -%}
              </span>
            </div>
          </div>

          {%- if cart.total_price < 10000 -%}
            {%- assign remaining = 10000 | minus: cart.total_price -%}
            <div class="gw-cart-summary__freeship">
              <div class="gw-cart-summary__freeship-bar">
                <div class="gw-cart-summary__freeship-fill" style="width:{{ cart.total_price | times: 100 | divided_by: 10000 | at_most: 100 }}%"></div>
              </div>
              <p>Noch <strong>{{ remaining | money }}</strong> bis zum kostenlosen Versand</p>
            </div>
          {%- endif -%}

          <div class="gw-cart-summary__total">
            <span>Gesamt</span>
            <span id="gw-cart-total">{{ cart.total_price | money }}</span>
          </div>
          <p class="gw-cart-summary__tax">inkl. MwSt.</p>

          <a href="/checkout" class="gw-cart-checkout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Sicher zur Kasse
          </a>

          <a href="/collections/all" class="gw-cart-continue">
            ← Weiter einkaufen
          </a>

          {%- comment -%} Trust badges {%- endcomment -%}
          <div class="gw-cart-trust">
            <div class="gw-cart-trust__item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              <span>SSL-gesichert</span>
            </div>
            <div class="gw-cart-trust__item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>14 Tage Rückgabe</span>
            </div>
            <div class="gw-cart-trust__item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>3–5 Tage Lieferzeit</span>
            </div>
          </div>

          {%- comment -%} Payment icons {%- endcomment -%}
          <p class="gw-cart-payment-label">Wir akzeptieren</p>
          <div class="gw-cart-payment">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'gw-cart-payment__icon' }}
            {%- endfor -%}
          </div>

        </div>
      </aside>

    </div>
  </div>
</div>

{%- endif -%}

<style>
/* ── Cart Page ───────────────────────────────────────────────────── */
.gw-cart-empty {
  background: var(--gw-ivory, #F9F6F0);
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}
.gw-cart-empty__inner {
  text-align: center;
  max-width: 400px;
}
.gw-cart-empty__icon svg {
  width: 64px; height: 64px;
  color: var(--gw-gold, #C89B3C);
  margin-bottom: 24px;
}
.gw-cart-empty__title {
  font-family: 'Fraunces', serif;
  font-size: 32px; font-weight: 400;
  letter-spacing: -0.02em;
  color: var(--gw-ink, #1A1613);
  margin: 0 0 12px;
}
.gw-cart-empty__text {
  font-family: 'Inter', system-ui, sans-serif;
  font-size: 15px; color: var(--gw-muted, #6B6560);
  margin: 0 0 28px; line-height: 1.6;
}
