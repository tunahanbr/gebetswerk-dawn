<section class="gw-hero">
  <div class="gw-hero__inner">

    {%- comment -%} Big hero card {%- endcomment -%}
    <div class="gw-hero__main">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 2000 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 750 }} 750w,
                  {{ section.settings.hero_image | image_url: width: 1100 }} 1100w,
                  {{ section.settings.hero_image | image_url: width: 1600 }} 1600w,
                  {{ section.settings.hero_image | image_url: width: 2000 }} 2000w"
          sizes="100vw"
          alt="{{ section.settings.hero_image.alt | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <img src="{{ 'hero-mat.jpg' | asset_url }}" alt="Gebetsteppich" width="1600" height="1000" loading="eager" fetchpriority="high">
      {%- endif -%}

      <div class="gw-hero__gradient"></div>

      {%- comment -%} Content overlay {%- endcomment -%}
      <div class="gw-hero__content">
        <p class="gw-hero__sub">{{ section.settings.hero_sub }}</p>
        <h1 class="gw-hero__heading">{{ section.settings.hero_heading | remove: '<p>' | remove: '</p>' }}</h1>
        <p class="gw-hero__desc">{{ section.settings.hero_desc }}</p>
        {%- comment -%} Buttons — eigene Blöcke im Theme-Editor {%- endcomment -%}
        {%- assign button_blocks = section.blocks | where: 'type', 'button' -%}
        {%- if button_blocks.size > 0 -%}
          <div class="gw-hero__buttons">
            {%- for block in button_blocks -%}
              {%- if block.settings.label != blank -%}
                {%- if block.settings.style == 'secondary' -%}
                  <a href="{{ block.settings.url }}" class="gw-btn-secondary" {{ block.shopify_attributes }}>
                    {{ block.settings.label }}
                  </a>
                {%- else -%}
                  <a href="{{ block.settings.url }}" class="gw-btn-primary" {{ block.shopify_attributes }}>
                    {{ block.settings.label }}
                    <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 15L15 5M15 5H7M15 5v8"/></svg>
                  </a>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- comment -%} Trust bar — Pills als eigene Blöcke {%- endcomment -%}
        {%- assign trust_pills = section.blocks | where: 'type', 'trust_pill' -%}
        {%- assign rating_pills = section.blocks | where: 'type', 'rating_pill' -%}
        {%- if trust_pills.size > 0 or rating_pills.size > 0 -%}
          <div class="gw-hero__trust-bar">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_pill' -%}
                <span class="gw-hero__trust-pill" {{ block.shopify_attributes }}>
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M9 11l3 3 5-6"/><path d="M20 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>
                  {{ block.settings.text }}
                </span>
              {%- elsif block.type == 'rating_pill' -%}
                <span class="gw-hero__trust-pill" {{ block.shopify_attributes }}>
                  <span class="gw-hero__trust-stars">
                    {%- for i in (1..5) -%}<svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>{%- endfor -%}
                  </span>
                  {%- comment -%} Live-Bewertung des gewählten Produkts, sonst Fallback-Texte {%- endcomment -%}
                  {%- assign rating_product = block.settings.rating_product | default: all_products['gebetsteppich'] -%}
                  {%- assign rp_rating = rating_product.metafields.reviews.rating.value -%}
                  {%- assign rp_count = rating_product.metafields.reviews.rating_count | times: 1 -%}
                  {%- if rp_count > 0 -%}
                    <strong>{{ rp_rating.rating | round: 1 | replace: '.', ',' }}</strong>&thinsp;·&thinsp;{{ rp_count }} Bewertung{% if rp_count != 1 %}en{% endif %}
                  {%- else -%}
                    <strong>{{ block.settings.rating_score }}</strong>&thinsp;·&thinsp;{{ block.settings.rating_count }}
                  {%- endif -%}
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} Bento cards — rendered from blocks, not clickable unless URL is set {%- endcomment -%}
    {%- assign card_blocks = section.blocks | where: 'type', 'bento_card' -%}
    {%- if card_blocks.size > 0 -%}
      <div class="gw-hero__cards gw-hero__cards--{{ card_blocks.size | at_most: 3 }}">
        {%- for block in card_blocks limit: 3 -%}
          {%- assign card_style = block.settings.card_style -%}
          {%- assign has_url = false -%}
          {%- if block.settings.card_url != blank -%}{%- assign has_url = true -%}{%- endif -%}

          {%- if has_url -%}
            <a href="{{ block.settings.card_url }}" class="gw-card gw-card--{{ card_style }}{%- if forloop.first %} gw-card--wide{%- endif %}" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="gw-card gw-card--{{ card_style }}{%- if forloop.first %} gw-card--wide{%- endif %}" {{ block.shopify_attributes }}>
          {%- endif -%}

            {%- if block.settings.card_image != blank -%}
              <img src="{{ block.settings.card_image | image_url: width: 900 }}" alt="{{ block.settings.card_title | escape }}" width="900" height="{{ 900 | divided_by: block.settings.card_image.aspect_ratio | round }}" loading="lazy">
            {%- endif -%}
            {%- if card_style == 'dark' -%}<div class="gw-card__gradient"></div>{%- endif -%}
            <div class="gw-card__body">
              {%- if block.settings.card_eyebrow != blank -%}
                <p class="gw-card__eyebrow">{{ block.settings.card_eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.card_title != blank -%}
                <p class="gw-card__title">{{ block.settings.card_title }}</p>
              {%- endif -%}
            </div>

          {%- if has_url -%}</a>{%- else -%}</div>{%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Steps strip — eigener Zähler, unabhängig von Bento-Karten {%- endcomment -%}
    {%- assign step_count = 0 -%}
    {%- assign has_steps = false -%}
    {%- for block in section.blocks -%}{%- if block.type == 'step' -%}{%- assign has_steps = true -%}{%- endif -%}{%- endfor -%}
    {%- if has_steps -%}
      <div class="gw-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            {%- assign step_count = step_count | plus: 1 -%}
            {%- if block.settings.step_number != blank -%}
              {%- assign display_num = block.settings.step_number -%}
            {%- elsif step_count < 10 -%}
              {%- assign display_num = step_count | prepend: '0' -%}
            {%- else -%}
              {%- assign display_num = step_count -%}
            {%- endif -%}
            <div class="gw-step" {{ block.shopify_attributes }}>
              <div class="gw-step__top">
                <span class="gw-step__num">{{ display_num }}</span>
                <svg class="gw-step__arrow" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 15L15 5M15 5H7M15 5v8"/></svg>
              </div>
              <p class="gw-step__title">{{ block.settings.step_title }}</p>
              <p class="gw-step__desc">{{ block.settings.step_desc }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  /* Misst die Höhe der Announcement-Bar und setzt --gw-topbar, damit der untere
     Rahmen des Heros exakt so breit ist wie oben/seitlich (unabhängig von ihrer Höhe). */
  (function () {
    function setTopbar() {
      var bar = document.querySelector('.utility-bar');
      var h = bar ? Math.round(bar.getBoundingClientRect().height) : 0;
      document.documentElement.style.setProperty('--gw-topbar', h + 'px');
    }
    setTopbar();
    window.addEventListener('resize', setTopbar, { passive: true });
    window.addEventListener('load', setTopbar);
  })();
</script>

{% schema %}
{
  "name": "Hero – Gebetswerk",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "🖼️ Hero-Bild & Text"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hintergrundbild",
      "info": "Empfohlen: mind. 2000 px breit"
    },
    {
      "type": "text",
      "id": "hero_sub",
      "label": "Kleiner Text über der Überschrift",
      "default": "Gebetsteppich für Baba & Anne"
    },
    {
      "type": "richtext",
      "id": "hero_heading",
      "label": "Haupt-Überschrift",
      "default": "<p>Ein Name. <em>Ein Gebet.</em> Ein Geschenk fürs Leben.</p>",
      "info": "Kursiv = goldene Schrift"
    },
    {
      "type": "textarea",
      "id": "hero_desc",
      "label": "Beschreibungstext",
      "default": "Personalisiere deinen Gebetsteppich mit Wunschnamen, Farbe und feinster Goldstickerei – sorgfältig in unserer Manufaktur gefertigt."
    },
    {
      "type": "paragraph",
      "content": "Buttons und Vertrauens-Pills sind eigene Blöcke — links unter 'Blöcke' hinzufügen und sortieren."
    }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "🔘 Button",
      "limit": 2,
      "settings": [
        { "type": "text", "id": "label", "label": "Beschriftung", "default": "Jetzt personalisieren" },
        { "type": "url",  "id": "url",   "label": "Link" },
        {
          "type": "select",
          "id": "style",
          "label": "Stil",
          "options": [
            { "value": "primary",   "label": "Gold (mit Pfeil)" },
            { "value": "secondary", "label": "Transparent" }
          ],
          "default": "primary"
        }
      ]
    },
    {
      "type": "trust_pill",
      "name": "✓ Vertrauens-Pill",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Manufaktur · Made in Europe" }
      ]
    },
    {
      "type": "rating_pill",
      "name": "⭐ Bewertungs-Pill",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "rating_product",
          "label": "Bewertung von Produkt",
          "info": "Zeigt die Live-Sternebewertung dieses Produkts. Leer = Produkt mit Handle 'gebetsteppich'. Ohne Reviews werden die Fallback-Werte genutzt."
        },
        { "type": "text", "id": "rating_score", "label": "Bewertungs-Score (Fallback)", "default": "4,9" },
        { "type": "text", "id": "rating_count", "label": "Bewertungsanzahl (Fallback)", "default": "1.240 Bewertungen" }
      ]
    },
    {
      "type": "bento_card",
      "name": "📦 Bento-Karte",
      "limit": 3,
      "settings": [
        {
          "type": "paragraph",
          "content": "Die erste Karte wird automatisch breiter dargestellt. Maximal 3 Karten."
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "card_eyebrow",
          "label": "Kleiner Text (oben)",
          "default": "Handarbeit",
          "info": "Kurzes Label über dem Titel"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Titel",
          "default": "Bestickt mit echtem Goldfaden"
        },
        {
          "type": "select",
          "id": "card_style",
          "label": "Farb-Stil",
          "options": [
            { "value": "dark", "label": "Dunkel (Gold-Text)" },
            { "value": "light", "label": "Hell (dunkler Text)" }
          ],
          "default": "dark"
        },
        {
          "type": "url",
          "id": "card_url",
          "label": "Link (optional)",
          "info": "Leer lassen → Karte ist nicht anklickbar"
        }
      ]
    },
    {
      "type": "step",
      "name": "✅ Prozess-Schritt",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Schrittnummer",
          "info": "Leer lassen → automatisch (01, 02, 03…). Eigene Zahl eingeben, z. B. '01' oder '1'"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Titel",
          "default": "Design wählen"
        },
        {
          "type": "text",
          "id": "step_desc",
          "label": "Beschreibung",
          "default": "Farbe, Stoff & Stickschrift bestimmen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero – Gebetswerk",
      "blocks": [
        {
          "type": "button",
          "settings": { "label": "Jetzt personalisieren", "style": "primary" }
        },
        {
          "type": "button",
          "settings": { "label": "Kollektion ansehen", "style": "secondary" }
        },
        {
          "type": "trust_pill",
          "settings": { "text": "Manufaktur · Made in Europe" }
        },
        {
          "type": "rating_pill",
          "settings": { "rating_score": "4,9", "rating_count": "1.240 Bewertungen" }
        },
        {
          "type": "bento_card",
          "settings": { "card_eyebrow": "Handarbeit", "card_title": "Bestickt mit echtem Goldfaden", "card_style": "dark" }
        },
        {
          "type": "bento_card",
          "settings": { "card_eyebrow": "Verpackung", "card_title": "Edler Geschenkkarton", "card_style": "light" }
        },
        {
          "type": "bento_card",
          "settings": { "card_eyebrow": "Detail", "card_title": "Jede Linie individuell gestickt", "card_style": "dark" }
        },
        {
          "type": "step",
          "settings": { "step_title": "Design wählen", "step_desc": "Farbe, Stoff & Stickschrift bestimmen" }
        },
        {
          "type": "step",
          "settings": { "step_title": "Personalisieren", "step_desc": "Bis zu zwei Namen und Symbole" }
        },
        {
          "type": "step",
          "settings": { "step_title": "Lieferung", "step_desc": "Versandfertig in 3–5 Tagen" }
        }
      ]
    }
  ]
}
{% endschema %}
