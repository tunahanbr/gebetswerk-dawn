{{ 'gebetswerk-collection-scroll.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign col    = section.settings.collection
  assign limit  = section.settings.products_to_show | default: 20
  assign prefix = section.settings.name_prefix | default: 'Personalisierter Gebetsteppich'
  assign suffix = section.settings.name_suffix | default: '· Geschenk'
-%}

<section class="gw-cscroll" id="gw-cscroll-{{ section.id }}">

  <div class="gw-cscroll__header">
    <div class="gw-cscroll__header-inner">
      {%- if section.settings.title != blank -%}
        <h2 class="gw-cscroll__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      <div class="gw-cscroll__controls">
        <button class="gw-cscroll__arrow gw-cscroll__prev" id="gw-prev-{{ section.id }}" aria-label="Zurück" disabled>
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 16l-6-6 6-6"/></svg>
        </button>
        <button class="gw-cscroll__arrow gw-cscroll__next" id="gw-next-{{ section.id }}" aria-label="Weiter">
          <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 4l6 6-6 6"/></svg>
        </button>
        {%- if section.settings.show_view_all and col != blank -%}
          <a href="{{ col.url }}" class="gw-cscroll__viewall">
            Alle ansehen
            <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 15L15 5M15 5H7M15 5v8"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="gw-cscroll__track-wrap">
    <div class="gw-cscroll__track">

      {%- if col != blank -%}
        {%- assign card_count = 0 -%}

        {%- for product in col.products -%}
          {%- if card_count >= limit -%}{%- break -%}{%- endif -%}

          {%- comment -%} Find the colour option {%- endcomment -%}
          {%- assign color_opt = nil -%}
          {%- for opt in product.options_with_values -%}
            {%- assign opt_lower = opt.name | downcase -%}
            {%- if opt_lower == 'farbe' or opt_lower == 'color' or opt_lower == 'colour' or opt_lower == 'farben' -%}
              {%- assign color_opt = opt -%}
            {%- endif -%}
          {%- endfor -%}

          {%- if color_opt != nil -%}
            {%- comment -%} One card per colour value {%- endcomment -%}
            {%- for color_val in color_opt.values -%}
              {%- if card_count >= limit -%}{%- break -%}{%- endif -%}

              {%- comment -%} Find first variant matching this colour {%- endcomment -%}
              {%- assign card_variant = nil -%}
              {%- for v in product.variants -%}
                {%- if v.options contains color_val -%}
                  {%- assign card_variant = v -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              {%- if card_variant == nil -%}{%- continue -%}{%- endif -%}

              {%- comment -%}
                Image: match the colour to the product image by filename, e.g.
                "…-gruen-verpackt.jpg" for "Grün". The variants have no images
                assigned in admin, so variant.featured_image is unreliable and
                can collapse to the single product image (black) for every
                colour — which is exactly the bug this avoids.
              {%- endcomment -%}
              {%- assign cslug = color_val | downcase | replace: 'ä', 'ae' | replace: 'ö', 'oe' | replace: 'ü', 'ue' | replace: 'ß', 'ss' | strip -%}
              {%- assign card_img  = nil -%}
              {%- assign hover_img = nil -%}
              {%- for img in product.images -%}
                {%- assign fname = img.src | split: '?' | first | downcase -%}
                {%- if fname contains cslug -%}
                  {%- if card_img == nil -%}
                    {%- assign card_img = img -%}
                  {%- elsif hover_img == nil -%}
                    {%- assign hover_img = img -%}
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}

              {%- comment -%} Fallbacks for products without colour-named images {%- endcomment -%}
              {%- if card_img == nil -%}
                {%- if card_variant.featured_image -%}
                  {%- assign card_img = card_variant.featured_image -%}
                {%- else -%}
                  {%- assign card_img = product.featured_media -%}
                {%- endif -%}
              {%- endif -%}
              {%- if hover_img == nil -%}
                {%- assign hover_img = product.media[1] -%}
              {%- endif -%}

              {%- assign card_url   = product.url | append: '?variant=' | append: card_variant.id -%}
              {%- assign card_title = prefix | append: ' – ' | append: color_val | append: ' ' | append: suffix -%}
              {%- assign card_price = card_variant.price -%}

              <a
                href="{{ card_url }}"
                class="gw-cscroll__card"
                aria-label="{{ card_title | escape }}"
                title="{{ card_title | escape }}"
              >
                <div class="gw-cscroll__img-wrap">
                  {%- if card_img -%}
                    <img
                      src="{{ card_img | image_url: width: 600 }}"
                      alt="{{ card_title | escape }}"
                      width="600"
                      height="{{ 600 | divided_by: card_img.aspect_ratio | round }}"
                      loading="lazy"
                    >
                    {%- if hover_img and hover_img != card_img -%}
                      <img
                        src="{{ hover_img | image_url: width: 600 }}"
                        alt="{{ card_title | escape }}"
                        width="600"
                        height="{{ 600 | divided_by: hover_img.aspect_ratio | round }}"
                        loading="lazy"
                        class="gw-cscroll__img-hover"
                      >
                    {%- endif -%}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-cscroll__placeholder' }}
                  {%- endif -%}
                  {%- if card_variant.available == false -%}
                    <span class="gw-cscroll__stock gw-cscroll__stock--sold">Ausverkauft</span>
                  {%- elsif card_variant.inventory_management and card_variant.inventory_quantity > 0 and card_variant.inventory_quantity <= 10 -%}
                    <span class="gw-cscroll__stock">Nur noch {{ card_variant.inventory_quantity }}</span>
                  {%- endif -%}
                </div>

                <div class="gw-cscroll__info">
                  <p class="gw-cscroll__color-label">{{ color_val }}</p>
                  <p class="gw-cscroll__name">{{ card_title }}</p>
                  <div class="gw-cscroll__rating">{% render 'gw-rating-stars', product: product %}</div>
                  <p class="gw-cscroll__price">{{ card_price | money }}</p>
                </div>
              </a>

              {%- assign card_count = card_count | plus: 1 -%}
            {%- endfor -%}

          {%- else -%}
            {%- comment -%} No colour option — show product as single card {%- endcomment -%}
            <a href="{{ product.url }}" class="gw-cscroll__card" aria-label="{{ product.title | escape }}">
              <div class="gw-cscroll__img-wrap">
                {%- if product.featured_media -%}
                  <img
                    src="{{ product.featured_media | image_url: width: 600 }}"
                    alt="{{ product.featured_media.alt | escape }}"
                    width="600"
                    height="{{ 600 | divided_by: product.featured_media.aspect_ratio | round }}"
                    loading="lazy"
                  >
                  {%- if product.media[1] -%}
                    <img
                      src="{{ product.media[1] | image_url: width: 600 }}"
                        alt="{{ product.title | escape }}"
                        width="600"
                        height="{{ 600 | divided_by: product.media[1].aspect_ratio | round }}"
                        loading="lazy"
                      class="gw-cscroll__img-hover"
                    >
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-cscroll__placeholder' }}
                {%- endif -%}
                {%- assign single_variant = product.selected_or_first_available_variant -%}
                {%- if product.available == false -%}
                  <span class="gw-cscroll__stock gw-cscroll__stock--sold">Ausverkauft</span>
                {%- elsif single_variant.inventory_management and single_variant.inventory_quantity > 0 and single_variant.inventory_quantity <= 10 -%}
                  <span class="gw-cscroll__stock">Nur noch {{ single_variant.inventory_quantity }}</span>
                {%- endif -%}
              </div>
              <div class="gw-cscroll__info">
                <p class="gw-cscroll__name">{{ product.title }}</p>
                <div class="gw-cscroll__rating">{% render 'gw-rating-stars', product: product %}</div>
                <p class="gw-cscroll__price">
                  {%- if product.price_varies -%}ab {% endif %}{{ product.price | money }}
                </p>
              </div>
            </a>
            {%- assign card_count = card_count | plus: 1 -%}
          {%- endif -%}

        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Placeholder cards when no collection is set {%- endcomment -%}
        {%- assign placeholder_colors = 'Weiß,Creme,Sand,Dunkelblau,Bordeaux,Schwarz' | split: ',' -%}
        {%- for color_val in placeholder_colors -%}
          <div class="gw-cscroll__card gw-cscroll__card--placeholder">
            <div class="gw-cscroll__img-wrap">
              {{ 'product-apparel-1' | placeholder_svg_tag: 'gw-cscroll__placeholder' }}
            </div>
            <div class="gw-cscroll__info">
              <p class="gw-cscroll__color-label">{{ color_val }}</p>
              <p class="gw-cscroll__name">{{ prefix }} – {{ color_val }} {{ suffix }}</p>
              <p class="gw-cscroll__price">ab 49,90 €</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div>
  </div>

</section>


<script>
(function() {
  var root  = document.getElementById('gw-cscroll-{{ section.id }}');
  var wrap  = root && root.querySelector('.gw-cscroll__track-wrap');
  var prev  = document.getElementById('gw-prev-{{ section.id }}');
  var next  = document.getElementById('gw-next-{{ section.id }}');
  if (!wrap || !prev || !next) return;

  function step() {
    var track = wrap.querySelector('.gw-cscroll__track');
    var card  = track && track.querySelector('.gw-cscroll__card');
    if (!card) return 780;
    var gap = track ? parseInt(getComputedStyle(track).columnGap) || 16 : 16;
    return (card.offsetWidth + gap) * 3;
  }

  function update() {
    prev.disabled = wrap.scrollLeft <= 1;
    next.disabled = wrap.scrollLeft >= wrap.scrollWidth - wrap.clientWidth - 1;
  }

  prev.addEventListener('click', function() { wrap.scrollBy({ left: -step(), behavior: 'smooth' }); });
  next.addEventListener('click', function() { wrap.scrollBy({ left:  step(), behavior: 'smooth' }); });
  wrap.addEventListener('scroll', update, { passive: true });
  update();
})();
</script>

{% schema %}
{
  "name": "Kollektion – Farbscroll",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Überschrift",
      "default": "Unsere Gebetsteppiche"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Max. Karten anzeigen",
      "min": 4,
      "max": 60,
      "step": 2,
      "default": 40
    },
    {
      "type": "header",
      "content": "SEO-Kartentitel"
    },
    {
      "type": "text",
      "id": "name_prefix",
      "label": "Präfix (vor Farbe)",
      "default": "Personalisierter Gebetsteppich",
      "info": "Wird zu: Personalisierter Gebetsteppich – Weiß · Geschenk"
    },
    {
      "type": "text",
      "id": "name_suffix",
      "label": "Suffix (nach Farbe)",
      "default": "· Geschenk für Mama & Baba"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "\"Alle ansehen\" anzeigen",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Kollektion – Farbscroll"
    }
  ]
}
{% endschema %}
