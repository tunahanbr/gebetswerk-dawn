{%- comment -%}
  Gesetzliches Muster-Widerrufsformular (Anhang zum FAGG / EU-Verbraucherrechte-RL).
  Der Wortlaut des Formulars ist gesetzlich vorgegeben und darf inhaltlich nicht
  verändert werden. Ausfüllbar am Bildschirm und druckbar (window.print()).
{%- endcomment -%}

<section class="gw-widerruf">
  <div class="gw-widerruf__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="gw-widerruf__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="gw-widerruf__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="gw-widerruf__card">
      <p class="gw-widerruf__hint">Wenn du den Vertrag widerrufen möchtest, fülle bitte dieses Formular aus und sende es an uns zurück.</p>

      <div class="gw-widerruf__to">
        <span class="gw-widerruf__label">An</span>
        <address class="gw-widerruf__address">
          {{ section.settings.company | escape | newline_to_br }}<br>
          {{ section.settings.address | escape | newline_to_br }}<br>
          {%- if section.settings.email != blank -%}E-Mail: {{ section.settings.email }}{%- endif -%}
        </address>
      </div>

      <p class="gw-widerruf__body">
        Hiermit widerrufe(n) ich/wir (*) den von mir/uns (*) abgeschlossenen Vertrag über den Kauf
        der folgenden Waren (*) / die Erbringung der folgenden Dienstleistung (*):
      </p>

      <div class="gw-widerruf__field">
        <label for="gw-wf-order">Bestellt am (*) / erhalten am (*)</label>
        <input type="text" id="gw-wf-order" autocomplete="off">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-name">Name des/der Verbraucher(s)</label>
        <input type="text" id="gw-wf-name" autocomplete="name">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-address">Anschrift des/der Verbraucher(s)</label>
        <input type="text" id="gw-wf-address" autocomplete="street-address">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-goods">Betroffene Ware(n) / Bestellnummer</label>
        <input type="text" id="gw-wf-goods" autocomplete="off">
      </div>
      <div class="gw-widerruf__field gw-widerruf__field--sign">
        <label for="gw-wf-date">Datum</label>
        <input type="text" id="gw-wf-date" autocomplete="off">
      </div>
      <p class="gw-widerruf__sign-note">Unterschrift des/der Verbraucher(s) (nur bei Mitteilung auf Papier):</p>
      <div class="gw-widerruf__sign-line" aria-hidden="true"></div>

      <p class="gw-widerruf__footnote">(*) Unzutreffendes streichen.</p>

      <div class="gw-widerruf__actions">
        <button type="button" class="gw-btn-primary" id="gw-wf-print">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Formular drucken / als PDF speichern
        </button>
        {%- if section.settings.email != blank -%}
          <a class="gw-widerruf__mail" href="mailto:{{ section.settings.email }}?subject=Widerruf%20meiner%20Bestellung">Alternativ per E-Mail widerrufen</a>
        {%- endif -%}
      </div>
    </div>

    <div class="gw-widerruf__contact-card">
      <div class="gw-widerruf__contact-intro">
        <span class="gw-widerruf__contact-kicker">Online übermitteln</span>
        <h3>Rücktrittserklärung absenden</h3>
        <p>Fülle die Angaben vollständig aus. Deine Erklärung wird über das sichere Shopify-Kontaktformular an die Shop-Absenderadresse gesendet.</p>
      </div>

      {%- form 'contact', id: 'GwWiderrufContactForm', class: 'gw-widerruf__contact-form' -%}
        {%- if form.posted_successfully? -%}
          <div class="gw-widerruf__success" role="status" tabindex="-1" autofocus>
            <strong>Deine Erklärung wurde an uns übermittelt.</strong>
            <span>Wir bestätigen den Eingang separat per E-Mail. Bitte bewahre diese Bestätigung auf.</span>
          </div>
        {%- elsif form.errors -%}
          <div class="gw-widerruf__error" role="alert">
            Bitte überprüfe deine E-Mail-Adresse und fülle alle Pflichtfelder aus.
          </div>
        {%- endif -%}

        <input type="hidden" name="contact[Anfrageart]" value="Rücktrittserklärung / Widerruf">

        <div class="gw-widerruf__form-grid">
          <div class="gw-widerruf__field">
            <label for="gw-wc-name">Name <span aria-hidden="true">*</span></label>
            <input id="gw-wc-name" type="text" name="contact[name]" autocomplete="name" required value="{% if form.name %}{{ form.name | escape }}{% elsif customer %}{{ customer.name | escape }}{% endif %}">
          </div>
          <div class="gw-widerruf__field">
            <label for="gw-wc-email">E-Mail-Adresse <span aria-hidden="true">*</span></label>
            <input id="gw-wc-email" type="email" name="contact[email]" autocomplete="email" required value="{% if form.email %}{{ form.email | escape }}{% elsif customer %}{{ customer.email | escape }}{% endif %}">
          </div>
        </div>

        <div class="gw-widerruf__form-grid">
          <div class="gw-widerruf__field">
            <label for="gw-wc-order">Bestellnummer <span aria-hidden="true">*</span></label>
            <input id="gw-wc-order" type="text" name="contact[Bestellnummer]" autocomplete="off" required>
          </div>
          <div class="gw-widerruf__field">
            <label for="gw-wc-order-date">Bestellt am / erhalten am</label>
            <input id="gw-wc-order-date" type="text" name="contact[Bestellt am / erhalten am]" autocomplete="off">
          </div>
        </div>

        <div class="gw-widerruf__field">
          <label for="gw-wc-goods">Betroffene Ware(n) <span aria-hidden="true">*</span></label>
          <input id="gw-wc-goods" type="text" name="contact[Betroffene Ware(n)]" required>
        </div>

        <div class="gw-widerruf__field">
          <label for="gw-wc-address">Anschrift</label>
          <textarea id="gw-wc-address" name="contact[Anschrift]" rows="3" autocomplete="street-address"></textarea>
        </div>

        <div class="gw-widerruf__field">
          <label for="gw-wc-body">Nachricht / eindeutige Erklärung <span aria-hidden="true">*</span></label>
          <textarea id="gw-wc-body" name="contact[body]" rows="5" required>Hiermit erkläre ich den Rücktritt vom oben genannten Kaufvertrag.</textarea>
        </div>

        <p class="gw-widerruf__privacy">Die Angaben werden zur Bearbeitung deiner Rücktrittserklärung verarbeitet. Weitere Informationen findest du in unserer <a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}">Datenschutzerklärung</a>.</p>

        <button type="submit" class="gw-btn-primary gw-widerruf__submit">Rücktrittserklärung absenden</button>
      {%- endform -%}
    </div>

  </div>
</section>

<style>
  .gw-widerruf { padding: 0 20px clamp(56px, 8vw, 96px); background: var(--gw-ivory, #f9f6f0); }
  .gw-widerruf__inner { max-width: 820px; margin: 0 auto; }
  .gw-widerruf__heading { font-family: var(--gw-font-heading, serif); font-size: clamp(24px, 4vw, 34px); font-weight: 400; margin: 0 0 12px; }
  .gw-widerruf__intro { color: var(--gw-muted, #6b6459); line-height: 1.6; margin: 0 0 24px; }
  .gw-widerruf__card, .gw-widerruf__contact-card { border: 1px solid var(--gw-border, #e3ddd2); border-radius: 20px; padding: clamp(22px, 4vw, 38px); background: #fffdf9; box-shadow: 0 12px 40px rgba(43, 38, 32, .05); }
  .gw-widerruf__hint { font-size: 13px; color: var(--gw-muted, #6b6459); margin: 0 0 20px; font-style: italic; }
  .gw-widerruf__label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: .06em; color: var(--gw-muted, #6b6459); }
  .gw-widerruf__address { font-style: normal; line-height: 1.5; margin: 4px 0 22px; }
  .gw-widerruf__body { line-height: 1.6; margin: 0 0 20px; }
  .gw-widerruf__field { margin-bottom: 16px; }
  .gw-widerruf__field label { display: block; font-size: 13px; color: var(--gw-muted, #6b6459); margin-bottom: 5px; }
  .gw-widerruf__field input {
    width: 100%; padding: 10px 12px; border: 1px solid var(--gw-border, #d9d2c6);
    border-radius: 8px; font-size: 15px; font-family: inherit; background: var(--gw-ivory, #faf8f3);
  }
  .gw-widerruf__field input:focus { outline: 2px solid var(--gw-gold, #c9a24a); outline-offset: 1px; }
  .gw-widerruf__sign-note { font-size: 13px; color: var(--gw-muted, #6b6459); margin: 20px 0 8px; }
  .gw-widerruf__sign-line { border-bottom: 1px solid var(--gw-border, #cfc7b9); height: 34px; }
  .gw-widerruf__footnote { font-size: 12px; color: var(--gw-muted, #6b6459); margin: 18px 0 0; }
  .gw-widerruf__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 26px; }
  .gw-widerruf__mail { font-size: 14px; color: var(--gw-ink, #2b2620); text-decoration: underline; text-underline-offset: 3px; }
  .gw-widerruf__contact-card { margin-top: 24px; background: var(--gw-sand, #ede8df); }
  .gw-widerruf__contact-intro { margin-bottom: 24px; }
  .gw-widerruf__contact-kicker { display: block; margin-bottom: 8px; color: var(--gw-gold-deep, #8a6820); font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; }
  .gw-widerruf__contact-intro h3 { margin: 0 0 8px; color: var(--gw-ink, #2b2620); font-family: var(--gw-font-heading, serif); font-size: clamp(24px, 4vw, 32px); font-weight: 400; letter-spacing: -.02em; }
  .gw-widerruf__contact-intro p { max-width: 620px; margin: 0; color: var(--gw-muted, #6b6459); font-size: 14px; line-height: 1.6; }
  .gw-widerruf__contact-form { padding-top: 22px; border-top: 1px solid var(--gw-border, #d9d1c4); }
  .gw-widerruf__form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
  .gw-widerruf__field { margin-bottom: 16px; }
  .gw-widerruf__field label { display: block; margin-bottom: 7px; color: var(--gw-ink, #2b2620); font-size: 13px; font-weight: 600; }
  .gw-widerruf__field label span { color: var(--gw-gold-deep, #8a6820); }
  .gw-widerruf__field input, .gw-widerruf__field textarea { width: 100%; padding: 12px 13px; border: 1px solid var(--gw-border, #d9d1c4); border-radius: 9px; background: #fffdf9; color: var(--gw-ink, #2b2620); font: inherit; font-size: 15px; }
  .gw-widerruf__field textarea { min-height: 96px; resize: vertical; }
  .gw-widerruf__field input:focus, .gw-widerruf__field textarea:focus { outline: 2px solid var(--gw-gold, #c9a24a); outline-offset: 1px; }
  .gw-widerruf__privacy { margin: 0 0 18px; color: var(--gw-muted, #6b6459); font-size: 12px; line-height: 1.5; }
  .gw-widerruf__privacy a { color: var(--gw-ink, #2b2620); text-underline-offset: 3px; }
  .gw-widerruf__submit { border: 0; cursor: pointer; }
  .gw-widerruf__success, .gw-widerruf__error { display: grid; gap: 4px; margin-bottom: 20px; padding: 14px 16px; border-radius: 10px; font-size: 14px; line-height: 1.5; }
  .gw-widerruf__success { background: #edf7ef; color: #245c31; }
  .gw-widerruf__error { background: #fff1ee; color: #8a2f22; }
  @media (max-width: 600px) { .gw-widerruf__form-grid { grid-template-columns: 1fr; gap: 0; } }
  @media print {
    body * { visibility: hidden; }
    .gw-widerruf, .gw-widerruf * { visibility: visible; }
    .gw-widerruf { position: absolute; inset: 0; padding: 0; }
    .gw-widerruf__card { border: none; padding: 0; }
    .gw-widerruf__actions { display: none; }
  }
</style>

<script>
  document.getElementById('gw-wf-print')?.addEventListener('click', function () { window.print(); });
</script>

{% schema %}
{
  "name": "Widerrufsformular",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Muster-Widerrufsformular" },
    { "type": "textarea", "id": "intro", "label": "Einleitung", "default": "Dieses Formular ist gesetzlich vorgegeben. Beachte: Für personalisierte Gebetsteppiche besteht kein Widerrufsrecht – das Formular gilt für nicht personalisierte Artikel." },
    { "type": "header", "content": "Empfänger (deine Firmendaten)" },
    { "type": "textarea", "id": "company", "label": "Firma / Name", "default": "[Firmenname / Inhaber]" },
    { "type": "textarea", "id": "address", "label": "Anschrift", "default": "[Straße Nr.]\n[PLZ Ort], Österreich" },
    { "type": "text", "id": "email", "label": "E-Mail", "default": "gebetswerk@gmail.com" }
  ],
  "presets": [{ "name": "Widerrufsformular" }]
}
{% endschema %}
