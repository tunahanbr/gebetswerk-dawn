{%- comment -%}
  Gesetzliches Muster-Widerrufsformular (Anhang zum FAGG / EU-Verbraucherrechte-RL).
  Der Wortlaut des Formulars ist gesetzlich vorgegeben und darf inhaltlich nicht
  verändert werden. Ausfüllbar am Bildschirm und druckbar (window.print()).
{%- endcomment -%}

<section class="gw-widerruf">
  <div class="gw-widerruf__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="gw-widerruf__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="gw-widerruf__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="gw-widerruf__card">
      <p class="gw-widerruf__hint">Wenn du den Vertrag widerrufen möchtest, fülle bitte dieses Formular aus und sende es an uns zurück.</p>

      <div class="gw-widerruf__to">
        <span class="gw-widerruf__label">An</span>
        <address class="gw-widerruf__address">
          {{ section.settings.company | escape | newline_to_br }}<br>
          {{ section.settings.address | escape | newline_to_br }}<br>
          {%- if section.settings.email != blank -%}E-Mail: {{ section.settings.email }}{%- endif -%}
        </address>
      </div>

      <p class="gw-widerruf__body">
        Hiermit widerrufe(n) ich/wir (*) den von mir/uns (*) abgeschlossenen Vertrag über den Kauf
        der folgenden Waren (*) / die Erbringung der folgenden Dienstleistung (*):
      </p>

      <div class="gw-widerruf__field">
        <label for="gw-wf-order">Bestellt am (*) / erhalten am (*)</label>
        <input type="text" id="gw-wf-order" autocomplete="off">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-name">Name des/der Verbraucher(s)</label>
        <input type="text" id="gw-wf-name" autocomplete="name">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-address">Anschrift des/der Verbraucher(s)</label>
        <input type="text" id="gw-wf-address" autocomplete="street-address">
      </div>
      <div class="gw-widerruf__field">
        <label for="gw-wf-goods">Betroffene Ware(n) / Bestellnummer</label>
        <input type="text" id="gw-wf-goods" autocomplete="off">
      </div>
      <div class="gw-widerruf__field gw-widerruf__field--sign">
        <label for="gw-wf-date">Datum</label>
        <input type="text" id="gw-wf-date" autocomplete="off">
      </div>
      <p class="gw-widerruf__sign-note">Unterschrift des/der Verbraucher(s) (nur bei Mitteilung auf Papier):</p>
      <div class="gw-widerruf__sign-line" aria-hidden="true"></div>

      <p class="gw-widerruf__footnote">(*) Unzutreffendes streichen.</p>

      <div class="gw-widerruf__actions">
        <button type="button" class="gw-btn-primary" id="gw-wf-print">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Formular drucken / als PDF speichern
        </button>
        {%- if section.settings.email != blank -%}
          <a class="gw-widerruf__mail" href="mailto:{{ section.settings.email }}?subject=Widerruf%20meiner%20Bestellung">Alternativ per E-Mail widerrufen</a>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  .gw-widerruf { padding: 40px 20px; }
  .gw-widerruf__inner { max-width: 680px; margin: 0 auto; }
  .gw-widerruf__heading { font-family: var(--gw-font-heading, serif); font-size: clamp(24px, 4vw, 34px); font-weight: 400; margin: 0 0 12px; }
  .gw-widerruf__intro { color: var(--gw-muted, #6b6459); line-height: 1.6; margin: 0 0 24px; }
  .gw-widerruf__card { border: 1px solid var(--gw-border, #e3ddd2); border-radius: 14px; padding: 28px; background: #fff; }
  .gw-widerruf__hint { font-size: 13px; color: var(--gw-muted, #6b6459); margin: 0 0 20px; font-style: italic; }
  .gw-widerruf__label { display: block; font-size: 12px; text-transform: uppercase; letter-spacing: .06em; color: var(--gw-muted, #6b6459); }
  .gw-widerruf__address { font-style: normal; line-height: 1.5; margin: 4px 0 22px; }
  .gw-widerruf__body { line-height: 1.6; margin: 0 0 20px; }
  .gw-widerruf__field { margin-bottom: 16px; }
  .gw-widerruf__field label { display: block; font-size: 13px; color: var(--gw-muted, #6b6459); margin-bottom: 5px; }
  .gw-widerruf__field input {
    width: 100%; padding: 10px 12px; border: 1px solid var(--gw-border, #d9d2c6);
    border-radius: 8px; font-size: 15px; font-family: inherit; background: var(--gw-ivory, #faf8f3);
  }
  .gw-widerruf__field input:focus { outline: 2px solid var(--gw-gold, #c9a24a); outline-offset: 1px; }
  .gw-widerruf__sign-note { font-size: 13px; color: var(--gw-muted, #6b6459); margin: 20px 0 8px; }
  .gw-widerruf__sign-line { border-bottom: 1px solid var(--gw-border, #cfc7b9); height: 34px; }
  .gw-widerruf__footnote { font-size: 12px; color: var(--gw-muted, #6b6459); margin: 18px 0 0; }
  .gw-widerruf__actions { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 26px; }
  .gw-widerruf__mail { font-size: 14px; color: var(--gw-ink, #2b2620); text-decoration: underline; text-underline-offset: 3px; }
  @media print {
    body * { visibility: hidden; }
    .gw-widerruf, .gw-widerruf * { visibility: visible; }
    .gw-widerruf { position: absolute; inset: 0; padding: 0; }
    .gw-widerruf__card { border: none; padding: 0; }
    .gw-widerruf__actions { display: none; }
  }
</style>

<script>
  document.getElementById('gw-wf-print')?.addEventListener('click', function () { window.print(); });
</script>

{% schema %}
{
  "name": "Widerrufsformular",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift", "default": "Muster-Widerrufsformular" },
    { "type": "textarea", "id": "intro", "label": "Einleitung", "default": "Dieses Formular ist gesetzlich vorgegeben. Beachte: Für personalisierte Gebetsteppiche besteht kein Widerrufsrecht – das Formular gilt für nicht personalisierte Artikel." },
    { "type": "header", "content": "Empfänger (deine Firmendaten)" },
    { "type": "textarea", "id": "company", "label": "Firma / Name", "default": "[Firmenname / Inhaber]" },
    { "type": "textarea", "id": "address", "label": "Anschrift", "default": "[Straße Nr.]\n[PLZ Ort], Österreich" },
    { "type": "text", "id": "email", "label": "E-Mail", "default": "[E-Mail-Adresse]" }
  ],
  "presets": [{ "name": "Widerrufsformular" }]
}
{% endschema %}
