<section class="gw-trust">
  <div class="gw-trust__inner">
    <div class="gw-trust__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'item' -%}
          <div class="gw-trust-item" {{ block.shopify_attributes }}>
            <div class="gw-trust-item__icon">
              {%- case block.settings.icon -%}
                {%- when 'truck' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3M9 17h6m-6 0a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm6 0a2 2 0 1 1 4 0 2 2 0 0 1-4 0zm5-6h-6V8l6 3z"/></svg>
                {%- when 'credit-card' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                {%- when 'heart' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {%- when 'shield' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                {%- when 'gift' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
              {%- endcase -%}
            </div>
            <div>
              <p class="gw-trust-item__title">{{ block.settings.title }}</p>
              <p class="gw-trust-item__text">{{ block.settings.text }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.footnote != blank -%}
      <p class="gw-trust__note">{{ section.settings.footnote }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Vertrauens-Leiste",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "footnote",
      "label": "Fußnote",
      "default": "*personalisierte Artikel sind ausgeschlossen"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Vertrauens-Element",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck",       "label": "Lieferwagen" },
            { "value": "credit-card", "label": "Kreditkarte" },
            { "value": "heart",       "label": "Herz" },
            { "value": "shield",      "label": "Schild" },
            { "value": "gift",        "label": "Geschenk" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Vertrauen"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Beschreibung",
          "default": "Kurze Beschreibung"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Vertrauens-Leiste",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "title": "Schneller Versand",
            "text": "Kostenlos ab 100 € (DE)"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "credit-card",
            "title": "3× zinsfrei mit Klarna",
            "text": "Bequem in Raten zahlen"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "heart",
            "title": "Persönlicher Service",
            "text": "Auch telefonisch erreichbar"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "shield",
            "title": "Zufriedenheitsgarantie",
            "text": "14 Tage Rückgaberecht*"
          }
        }
      ]
    }
  ]
}
{% endschema %}
